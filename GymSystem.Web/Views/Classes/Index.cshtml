@using GymSystem.Shared.DTOs
@{
    ViewData["Title"] = "Classes";
    var classes = ViewBag.Classes as List<ClassDTO> ?? new List<ClassDTO>();
    var trainerNames = classes.Select(c => c.TrainerName).Distinct().ToList();

    var icons = new[] { "bi-heart-fill", "bi-bar-chart-line", "bi-lightning-fill", "bi-person", "bi-shield", "bi-fire", "bi-trophy", "bi-stars" };
}

@section Styles {
  <link rel="stylesheet" href="~/css/members/classes.css" asp-append-version="true"/>
}

  <!-- TOP SECTION -->
  <div class="top-section">

    <h1 class="page-title reveal">Classes and Personal Trainers</h1>

    <div id="carouselExampleIndicators" class="carousel slide reveal" data-bs-ride="carousel">
  <div class="carousel-indicators" >
    <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
    <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="1" aria-label="Slide 2"></button>
    <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="2" aria-label="Slide 3"></button>
  </div>
  <div class="carousel-inner" style="border-radius: 13px; width: 100%; height: 580px; margin: 20px;">
    <div class="carousel-item active ">
      <img src="images/people-working-out-indoors-together-with-dumbbells.jpg" class="d-block w-100" alt="Gym class image">
    </div>
    <div class="carousel-item" >
      <img src="images/pilates-group-working-out-gym.jpg" class="d-block w-100" alt="Gym class image">
    </div>
    <div class="carousel-item">
      <img src="images/athletic-people-training-boxing-competition.jpg" class="d-block w-100" alt="Gym class image">
    </div>
  </div>
  <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="prev">
    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Previous</span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="next">
    <span class="carousel-control-next-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Next</span>
  </button>
</div>

    <!-- Class Type -->
    <div id="class-type" class="section-label reveal">
      Class Type
     <i class="bi bi-arrow-right"></i>
    </div>

    <div class="class-type-row reveal">
      @if (classes.Any())
      {
        var pillIndex = 0;
        @foreach (var cls in classes)
        {
          var slug = cls.Subject.ToLower().Replace(" ", "-");
          var icon = icons[pillIndex % icons.Length];
          var activeClass = pillIndex == 0 ? "active" : "";
          <div class="class-pill @activeClass" onclick="scrollToClass('@slug')">
            <div class="class-pill-icon">
              <i class="bi @icon"></i>
            </div>
            <span class="class-pill-label">@cls.Subject</span>
          </div>
          pillIndex++;
        }
      }
      else
      {
        <p style="color: #ccc;">No classes available at the moment.</p>
      }
    </div>

    <!-- Personal Training -->
    <div id="personal-training" class="section-label reveal">Personal Training</div>

<div class="personal-training-row reveal">
@if (trainerNames.Any())
{
  @foreach (var name in trainerNames)
  {
    <div class="pt-pill text-center">
      <img src="images/Char1.jpg" class="rounded-circle mb-2" width="80" height="80" alt="@name">
      <div class="fw-bold">@name</div>
    </div>
  }
}
else
{
  <p>No trainers available at the moment.</p>
}
 </div>
  </div>

  <!-- FULL WIDTH CLASS ROWS -->
  <div class="classes-list">
    @if (classes.Any())
    {
      var rowIndex = 0;
      @foreach (var cls in classes)
      {
        var slug = cls.Subject.ToLower().Replace(" ", "-");
        var isLeft = rowIndex % 2 == 0;
        var layoutClass = isLeft ? "info-left" : "info-right";
        var bgClass = isLeft ? "bg-red" : "bg-black";

        <div class="class-row @layoutClass reveal" id="@slug">
          <div class="class-info-panel">
            <div class="class-name">@cls.Subject</div>
            <div class="class-tagline">Trainer: @cls.TrainerName</div>
            <p class="class-desc">
              This class currently has @cls.SessionCount scheduled session@(cls.SessionCount != 1 ? "s" : "").
              Join now to view all session times, availability, and book your spot instantly.
            </p>
            <a asp-area="Member" asp-controller="Booking" asp-action="Index" class="join-btn">Book a Session</a>
          </div>
          <div class="class-bg-panel @bgClass"></div>
        </div>

        rowIndex++;
      }
    }
    else
    {
      <div style="text-align:center;padding:60px;color:#ccc;">
        <h2>No classes available</h2>
        <p>Check back soon — new classes are being added regularly.</p>
      </div>
    }

    <!-- Scroll to Top Button -->
    <button class="scroll-top-btn" id="scrollTopBtn" onclick="window.scrollTo({top: 0, behavior: 'smooth'})">
  <i class="bi bi-arrow-up"></i>
</button>

<!-- Questions and answers -->
      <div class="faq-section reveal">
        <h2 class="faq-title">Common Questions</h2>
        <div class="faq-list">

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">What are the benefits of joining a gym class?</div>
            </div>
            <p class="faq-answer">Joining a gym class keeps you motivated, focused, and pushing your limits. With our expert fitness instructors guiding every move, you get the best workout and the support of a community cheering you on. Classes add variety, help you stay consistent, and boost your mental wellbeing by reducing stress and lifting your mood.</p>
          </div>

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Do workout classes build muscle?</div>
            </div>
            <p class="faq-answer">Yes, workout classes can help build muscle, especially strength training and HIIT classes.</p>
          </div>

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Can you lose weight doing gym classes?</div>
            </div>
            <p class="faq-answer">Yes, you can lose weight by participating in gym classes. Classes like HIIT and cardio are particularly effective for weight loss. <br> Combining regular workouts (3–5 times a week) with a balanced diet and consistent effort can help you slim down, tone up, and feel stronger.</p>
          </div>

        </div>
      </div>


  </div>

  <script>
    document.querySelectorAll('.class-pill').forEach(pill => {
      pill.addEventListener('click', () => {
        document.querySelectorAll('.class-pill').forEach(p => p.classList.remove('active'));
        pill.classList.add('active');
      });
    });

    function scrollToClass(id) {
      const el = document.getElementById(id);
      if (el) {
        const offset = el.getBoundingClientRect().top + window.scrollY - 90;
        window.scrollTo({ top: offset, behavior: 'smooth' });
      }
    }
  </script>

@section Scripts {
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
}