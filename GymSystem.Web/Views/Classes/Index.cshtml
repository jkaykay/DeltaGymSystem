    <!-- Scroll to Top Button -->
    <button class="scroll-top-btn" id="scrollTopBtn" onclick="window.scrollTo({top: 0, behavior: 'smooth'})">
  <i class="bi bi-arrow-up"></i>
</button>

<!-- Questions and answers -->
      <div class="faq-section reveal">
        <h2 class="faq-title">Common Questions</h2>
        <div class="faq-list">

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">What are the benefits of joining a gym class?</div>
            </div>
            <p class="faq-answer">Joining a gym class keeps you motivated, focused, and pushing your limits. With our expert fitness instructors guiding every move, you get the best workout and the support of a community cheering you on. Classes add variety, help you stay consistent, and boost your mental wellbeing by reducing stress and lifting your mood.</p>
          </div>

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Do workout classes build muscle?</div>
            </div>
            <p class="faq-answer">Yes, workout classes can help build muscle, especially strength training and HIIT classes.</p>
          </div>

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Can you lose weight doing gym classes?</div>
            </div>
            <p class="faq-answer">Yes, you can lose weight by participating in gym classes. Classes like HIIT and cardio are particularly effective for weight loss. <br> Combining regular workouts (3–5 times a week) with a balanced diet and consistent effort can help you slim down, tone up, and feel stronger.</p>
          </div>

        </div>
      </div>


  </div>

  <script>
    const nav = document.querySelector('nav');
    window.addEventListener('scroll', () => {
      nav.style.boxShadow = window.scrollY > 10 ? '0 4px 24px rgba(0,0,0,0.08)' : 'none';
    });

    document.querySelectorAll('.class-pill').forEach(pill => {
      pill.addEventListener('click', () => {
        document.querySelectorAll('.class-pill').forEach(p => p.classList.remove('active'));
        pill.classList.add('active');
      });
    });

    const items = document.querySelectorAll('.reveal');
    items.forEach((el, i) => el.style.transitionDelay = `${i * 60}ms`);

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }
      });
    }, { threshold: 0.08 });
    items.forEach(el => observer.observe(el));

    function scrollToClass(id) {
  const el = document.getElementById(id);
  if (el) {
    const offset = el.getBoundingClientRect().top + window.scrollY - 90;
    window.scrollTo({ top: offset, behavior: 'smooth' });
  }
}

// Show/hide scroll to top button
const scrollTopBtn = document.getElementById('scrollTopBtn');
window.addEventListener('scroll', () => {
  if (window.scrollY > 400) {
    scrollTopBtn.classList.add('visible');
  } else {
    scrollTopBtn.classList.remove('visible');
  }
});

  </script>

@section Scripts {
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
