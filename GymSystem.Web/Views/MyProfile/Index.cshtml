@{
    Layout= null;
}

@{
    ViewData["Title"] = "My Profile";
}


<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>DELTA GYMS-MyProfile</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="css/myprofile.css" /> 
</head>
<body>

  <!-- NAV  BAR-->
  <nav>
    <div class="nav-logo">
      <img src="images/logo.png" alt="Delta Gyms Logo" class="nav-logo-img"/>
    </div>
<ul class="nav-links">
      <li><a asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
      <li><a asp-area="" asp-controller="Classes" asp-action="Index">Classes</a></li>
      <li><a asp-area="" asp-controller="Memberships" asp-action="Index">Memberships</a></li>
      <li><a asp-area="Member" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
      <li><a asp-area="Member" asp-controller="MyProfile" asp-action="Index">MyProfile</a></li>
      <li><a asp-area="" asp-controller="Support" asp-action="Index">Support</a></li>
    </ul>
    <div class="nav-logout"><a href="#">Logout</a></div>
  </nav>

   <!-- PAGE -->
  <div class="page">

    <!-- Edit / Back row -->
    <div class="edit-row reveal">
      <button class="edit-btn" title="Edit profile">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
        </svg>
      </button>
    </div>

    <!-- Page Title -->
    <h1 class="profile-page-title reveal">MY PROFILE</h1>

    <!-- Profile top grid -->
    <div class="profile-grid reveal">

      <!-- Left: User info -->
      <div>
        <div class="user-name">USER NAME</div>
        <div class="membership-badge">CURRENT MEMBERSHIP</div>
        <div class="membership-price">
          <span class="dollar">$</span>
          <span class="amount">19.99</span>
        </div>
        <div class="full-name-label">FULL NAME</div>
      </div>

      <!--Member code -->
      <div class="member-code-card">
        <div class="member-code-title">MEMBER CODE</div>
        <div class="member-code-body">
          <!-- QR code placeholder SVG -->
          <div class="qr-wrap">
            <svg viewBox="0 0 72 72" xmlns="http://www.w3.org/2000/svg" width="72" height="72">
              <!-- Outer border squares -->
              <rect x="2" y="2" width="26" height="26" rx="3" fill="none" stroke="#111" stroke-width="3"/>
              <rect x="8" y="8" width="14" height="14" rx="1" fill="#111"/>
              <rect x="44" y="2" width="26" height="26" rx="3" fill="none" stroke="#111" stroke-width="3"/>
              <rect x="50" y="8" width="14" height="14" rx="1" fill="#111"/>
              <rect x="2" y="44" width="26" height="26" rx="3" fill="none" stroke="#111" stroke-width="3"/>
              <rect x="8" y="50" width="14" height="14" rx="1" fill="#111"/>
              <!-- Data dots -->
              <rect x="32" y="2" width="6" height="6" fill="#111"/>
              <rect x="32" y="10" width="6" height="6" fill="#111"/>
              <rect x="32" y="18" width="6" height="6" fill="#111"/>
              <rect x="40" y="32" width="6" height="6" fill="#111"/>
              <rect x="48" y="32" width="6" height="6" fill="#111"/>
              <rect x="56" y="32" width="6" height="6" fill="#111"/>
              <rect x="64" y="32" width="6" height="6" fill="#111"/>
              <rect x="32" y="32" width="6" height="6" fill="#111"/>
              <rect x="2" y="32" width="6" height="6" fill="#111"/>
              <rect x="10" y="32" width="6" height="6" fill="#111"/>
              <rect x="18" y="32" width="6" height="6" fill="#111"/>
              <rect x="40" y="40" width="6" height="6" fill="#111"/>
              <rect x="56" y="40" width="6" height="6" fill="#111"/>
              <rect x="48" y="48" width="6" height="6" fill="#111"/>
              <rect x="64" y="48" width="6" height="6" fill="#111"/>
              <rect x="40" y="56" width="6" height="6" fill="#111"/>
              <rect x="56" y="56" width="6" height="6" fill="#111"/>
              <rect x="48" y="64" width="6" height="6" fill="#111"/>
              <rect x="64" y="64" width="6" height="6" fill="#111"/>
              <!-- SCAN ME label -->
              <text x="36" y="78" text-anchor="middle" font-size="7" font-family="sans-serif" font-weight="700" fill="#111">SCAN ME</text>
            </svg>
          </div>
          <div class="member-code-info">
            <div class="code-value">" CODE "</div>
            <div class="code-hint">Show at front desk if needed</div>
          </div>
        </div>
      </div>

    </div>

    <!-- Fields -->
    <div class="fields-section reveal">
      <div class="fields-row">
        <div class="field-group">
          <span class="field-label">Telephone</span>
          <div class="field-box">Value</div>
        </div>
        <div class="field-group">
          <span class="field-label">Email</span>
          <div class="field-box">Value</div>
        </div>
      </div>

      <div class="fields-row">
      <div class="field-group">
        <span class="field-label">Emergency Contact</span>
        <div class="field-box">Value</div>
      </div>
    

    <div class="field-group">
        <span class="field-label">Current Weight</span>
        <div class="field-box">Value</div>
    </div>
    </div>

  </div>

  <script>
    // Nav shadow on scroll
    const nav = document.querySelector('nav');
    window.addEventListener('scroll', () => {
      nav.style.boxShadow = window.scrollY > 10
        ? '0 4px 24px rgba(0,0,0,0.08)'
        : 'none';
    });

    // Scroll reveal with stagger
    const items = document.querySelectorAll('.reveal');
    items.forEach((el, i) => {
      el.style.transitionDelay = `${i * 80}ms`;
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.08 });
    items.forEach(el => observer.observe(el));
  </script>
</body>
</html>


