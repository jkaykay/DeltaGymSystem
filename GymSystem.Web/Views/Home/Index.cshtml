    </ul>
    <div class="nav-logout"><a href="#">Logout</a></div>
  </nav>


    <!-- Logout -->
    <div class="modal fade" id="logoutModal" tabindex="-1">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Confirm Logout</h5> <!-- Logout confirmation title -->
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            Are you sure you want to end your session?
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button> <!-- Cancel button and it returns back to the same place-->
            <button type="button" class="btn btn-danger" onclick="window.location.href='login.html'">Logout</button> <!-- Confirm logout button  -->
          </div>
        </div>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-top">
        <h1 class="hero-headline">Push Your<br>Limits</h1>
        <div class="hero-cta">
          <button class="btn-primary" onclick="window.location.href='memberships.html'">Join Now</button>
          <button class="btn-outline" onclick="window.location.href='classes.html'">Browse Classes</button>
        </div>
