        </div>
        <div class="card-body">
          <div class="card-name">HIIT Blast</div>
          <div class="card-trainer">Samy John</div>
          <div class="card-meta">
            <span>45 min</span>
            <span class="spots"><span class="smiley">😊</span> 16/25</span>
          </div>
        </div>
        <a href="booking.html" class="card-footer">JOIN CLASS</a>
      </div>

      <!-- Card 3 -->
