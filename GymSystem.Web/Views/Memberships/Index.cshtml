@using GymSystem.Shared.DTOs
@{
    ViewData["Title"] = "Memberships";
    var tiers = ViewBag.Tiers as List<TierDTO> ?? new List<TierDTO>();
    var featured = tiers.OrderByDescending(t => t.SubCount).FirstOrDefault();
}

@section Styles {
  <link href="~/css/members/stylememberships.css" rel="stylesheet" asp-append-version="true"/>
}

  <!-- PAGE -->
  <div class="page">
    <div class="page-inner">

      <!-- Header -->
      <div class="page-header reveal">
        <p class="eyebrow">Pricing and Details</p>
        <h1>Choose Your Membership</h1>
      </div>

      <!-- Plans -->
      <div class="plans-grid reveal">
        @if (tiers.Any())
        {
          @foreach (var tier in tiers)
          {
            var isFeatured = featured != null && tier.TierName == featured.TierName;
            <div class="plan-card @(isFeatured ? "featured" : "")">
              @if (isFeatured)
              {
                <div class="popular-badge">MOST POPULAR</div>
              }
              <div class="plan-name">@tier.TierName</div>
              <div class="plan-price">
                <span class="dollar">$</span><span class="amount">@tier.Price.ToString("F2")</span><span class="period"> / mo</span>
              </div>
              <ul class="plan-features">
                <li>Full gym access</li>
                <li>Locker room access</li>
                <li>@tier.SubCount active subscribers</li>
              </ul>
              <a asp-area="Member" asp-controller="Subscribe" asp-action="Index" asp-route-tier="@tier.TierName" class="plan-btn">Get started</a>
            </div>
          }
        }
        else
        {
          <p>Membership plans coming soon.</p>
        }
      </div>

      <!-- FAQ -->
      <div class="faq-section reveal">
        <h2 class="faq-title">Common Questions</h2>
        <div class="faq-list">

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Can I switch plans anytime?</div>
            </div>
            <p class="faq-answer">You make purchases month by month. You'd have to wait for your current month's plan to expire before the upgraded plan is applied.</p>
          </div>

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Is there a contract?</div>
            </div>
            <p class="faq-answer">No contracts. All plans are monthly based, and you can cancel anytime by choosing to not purchase any more months.</p>
          </div>

        </div>
      </div>

      </div>
  </div>
