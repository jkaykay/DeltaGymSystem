@using GymSystem.Shared.DTOs
@{
    ViewData["Title"] = "Memberships";
    var tiers = ViewBag.Tiers as List<TierDTO> ?? new List<TierDTO>();
    var featured = tiers.OrderByDescending(t => t.SubCount).FirstOrDefault();
    var deltaAnswer = ViewBag.DeltaAnswer as string;
    var deltaPrompt = ViewBag.DeltaPrompt as string;
}

@section Styles {
  <link href="~/css/members/stylememberships.css" rel="stylesheet" asp-append-version="true"/>
}

  <!-- PAGE -->
  <div class="page">
    <div class="page-inner">

      <!-- Header -->
      <div class="page-header reveal">
        <p class="eyebrow">Pricing and Details</p>
        <h1>Choose Your Membership</h1>
      </div>

      <!-- Plans -->
      <div class="plans-grid reveal">
        @if (tiers.Any())
        {
          @foreach (var tier in tiers)
          {
            var isFeatured = featured != null && tier.TierName == featured.TierName;
            <div class="plan-card @(isFeatured ? "featured" : "")">
              @if (isFeatured)
              {
                <div class="popular-badge">MOST POPULAR</div>
              }
              <div class="plan-name">@tier.TierName</div>
              <div class="plan-price">
                <span class="dollar">$</span><span class="amount">@tier.Price.ToString("F2")</span><span class="period"> / mo</span>
              </div>
              <ul class="plan-features">
                <li>Full gym access</li>
                <li>Locker room access</li>
                <li>@tier.SubCount active subscribers</li>
              </ul>
              <a asp-area="Member" asp-controller="Subscribe" asp-action="Index" asp-route-tier="@tier.TierName" class="plan-btn">Get started</a>
            </div>
          }
        }
        else
        {
          <p>Membership plans coming soon.</p>
        }
      </div>

      <!-- FAQ -->
      <div class="faq-section reveal">
        <h2 class="faq-title">Common Questions</h2>
        <div class="faq-list">

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Can I switch plans anytime?</div>
            </div>
            <p class="faq-answer">Yes, you can upgrade or downgrade your plans at anytime. Changes take effect immediately.</p>
          </div>

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Is there a contract?</div>
            </div>
            <p class="faq-answer">No contracts. All plans are monthly based, and you can cancel anytime.</p>
          </div>

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Can I freeze my membership?</div>
            </div>
            <p class="faq-answer">Yes, you can freeze your membership for up to 3 months per year. Simply contact support to request a freeze.</p>
          </div>

        </div>
      </div>

      <!-- Ask Delta -->
      <div class="ask-delta-wrap reveal">
        <div class="ask-delta">
          <div class="ask-delta-title">"Ask DELTA"</div>
          <form asp-controller="Memberships" asp-action="AskDelta" method="post">
            @Html.AntiForgeryToken()
            <div class="ask-delta-input">
              <div class="ask-delta-avatar">
                <img src="images/Dumbell.png" alt="Delta Gyms Logo" class="nav-logo-img"/>
              </div>
              <input type="text" name="prompt" value="@deltaPrompt" placeholder="What is your question?" />
              <button type="submit" style="background:#e63946;color:#fff;border:none;padding:0.5rem 1rem;border-radius:8px;cursor:pointer;margin-left:0.5rem;">Ask</button>
            </div>
          </form>
          @if (!string.IsNullOrEmpty(deltaAnswer))
          {
            <div style="background:rgba(255,255,255,0.05);border-radius:12px;padding:1rem;margin-top:1rem;color:#ccc;line-height:1.6;">
              @deltaAnswer
            </div>
          }
        </div>
      </div>

    </div>
  </div>

