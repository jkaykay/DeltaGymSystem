@{
    Layout = null;
}

@{
    ViewData["Title"] = "Memberships";
}

<!DOCTYPE html>
<html lang="en">




<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>DeltaGyms-Memberships</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="~/css/members/stylememberships.css" rel="stylesheet" asp-append-version="true"/>
</head>
<body>

  <!-- NAV BAR -->
  <nav>
    <div class="nav-logo">
      <img src="~/images/logo.png" alt="Delta Gyms Logo" class="nav-logo-img"/>
    </div>
    <ul class="nav-links">
      <li><a asp-area="" asp-controller="Home" asp-action="Index" class="active">Home</a></li>
      <li><a asp-area="" asp-controller="Classes" asp-action="Index">Classes</a></li>
      <li><a asp-area="" asp-controller="Memberships" asp-action="Index">Memberships</a></li>
      <li><a asp-area="Member" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
      <li><a asp-area="Member" asp-controller="MyProfile" asp-action="Index">MyProfile</a></li>
      <li><a asp-area="" asp-controller="About" asp-action="Index">About</a></li>
    </ul>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
      <form asp-area="Member" asp-controller="Login" asp-action="Logout" method="post" class="nav-logout">
        @Html.AntiForgeryToken()
        <button type="submit" class="logout-btn">
          Logout
        </button>
      </form>
    }
    else
    {
        <div class="nav-logout">
            <a asp-area="Member" asp-controller="Login" asp-action="Index">
                Login
            </a>
        </div>
    }
  </nav>

  <!-- PAGE -->
  <div class="page">
    <div class="page-inner">

      <!-- Header -->
      <div class="page-header reveal">
        <p class="eyebrow">Pricing and Details</p>
        <h1>Choose Your Membership</h1>
      </div>

      <!-- Plans -->
      <div class="plans-grid reveal">

        <div class="plan-card">
          <div class="plan-name">Basic</div>
          <div class="plan-price">
            <span class="dollar">$</span><span class="amount">19.99</span><span class="period"> / mo</span>
          </div>
          <ul class="plan-features">
            <li>Access to GYM (Not in Peak)</li>
            <li>Locker room access</li>
            <li>1 free class per week</li>
            <li>Basic fitness assessments</li>
          </ul>
          <a asp-area="Member" asp-controller="Subscribe" asp-action="Index" class="plan-btn">Get started</a>
        </div>

        <div class="plan-card featured">
          <div class="popular-badge">MOST POPULAR</div>
          <div class="plan-name">Pro</div>
          <div class="plan-price">
            <span class="dollar">$</span><span class="amount">39.99</span><span class="period"> / mo</span>
          </div>
          <ul class="plan-features">
            <li>Anytime GYM access</li>
            <li>Unlimited classes</li>
            <li>Personal Locker</li>
            <li>Sauna and steam room free</li>
          </ul>
          <a asp-area="Member" asp-controller="Subscribe" asp-action="Index" class="plan-btn">Get started</a>
        </div>

      </div>

      <!-- FAQ -->
      <div class="faq-section reveal">
        <h2 class="faq-title">Common Questions</h2>
        <div class="faq-list">

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Can I switch plans anytime?</div>
            </div>
            <p class="faq-answer">Yes, you can upgrade or downgrade your plans at anytime. Changes take effect immediately.</p>
          </div>

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Is there a contract?</div>
            </div>
            <p class="faq-answer">No contracts. All plans are monthly based, and you can cancel anytime.</p>
          </div>

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Can I freeze my membership?</div>
            </div>
            <p class="faq-answer">Yes, you can freeze your membership for up to 3 months per year. Simply contact support to request a freeze.</p>
          </div>

        </div>
      </div>

      <!-- Ask Delta -->
        <div class="ask-delta-wrap">
            <div class="ask-delta">
                <div class="ask-delta-title">Ask DELTA</div>

                <form id="deltaChatForm">
                    @Html.AntiForgeryToken()

                    <div class="ask-delta-input">
                        <div class="ask-delta-avatar">
                            <img src="/images/LOGO.png" alt="DELTA" />
                        </div>

                        <textarea id="deltaMessage"
                                    placeholder="Ask about memberships, plans, or pricing..."
                                    rows="2"></textarea>
                    </div>

                    <div id="deltaLoading" class="ask-delta-loading" style="display:none;">
                        DELTA is thinking...
                    </div>

                    <div id="deltaReply" class="ask-delta-response" style="display:none;"></div>

                    <button type="button" id="deltaSendBtn" class="ask-delta-send">
                        Send
                    </button>
                </form>
            </div>
        </div>

    </div>
  </div>

  <!-- Scroll to Top Button -->
  <button class="scroll-top-btn" id="scrollTopBtn" onclick="window.scrollTo({top: 0, behavior: 'smooth'})">
    <i class="bi bi-arrow-up"></i>
  </button>

  <script>
    // Sticky nav shadow
    const nav = document.querySelector('nav');
    window.addEventListener('scroll', () => {
      nav.style.boxShadow = window.scrollY > 10
        ? '0 4px 24px rgba(0,0,0,0.10)'
        : 'none';
    });

    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // Show/hide scroll to top button
    const scrollTopBtn = document.getElementById('scrollTopBtn');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        scrollTopBtn.classList.add('visible');
      } else {
        scrollTopBtn.classList.remove('visible');
      }
    });
  </script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const messageBox = document.getElementById("deltaMessage");
            const replyBox = document.getElementById("deltaReply");
            const loadingText = document.getElementById("deltaLoading");
            const sendBtn = document.getElementById("deltaSendBtn");

            if (!messageBox || !replyBox || !loadingText || !sendBtn) return;

            sendBtn.addEventListener("click", async function () {
                const message = messageBox.value.trim();

                replyBox.style.display = "none";
                loadingText.style.display = "none";
                replyBox.innerText = "";

                if (!message) {
                    replyBox.style.display = "block";
                    replyBox.innerText = "Please type a question first.";
                    return;
                }

                loadingText.style.display = "block";
                sendBtn.disabled = true;

                try {
                    const response = await fetch("https://localhost:7183/api/LLM/chat", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify({ prompt: message })
                    });

                    const data = await response.json();

                    loadingText.style.display = "none";
                    sendBtn.disabled = false;
                    replyBox.style.display = "block";

                    if (!response.ok) {
                        replyBox.innerText = data.error || "Something went wrong while contacting DELTA.";
                        return;
                    }

                    replyBox.innerText = data.response ?? "Sorry, I couldn't get a response.";
                } catch (error) {
                    loadingText.style.display = "none";
                    sendBtn.disabled = false;

                    replyBox.style.display = "block";
                    replyBox.innerText = "Something went wrong while contacting DELTA.";
                    console.error("Chatbot error:", error);
                }
            });
        });
    </script>
</body>
</html>
