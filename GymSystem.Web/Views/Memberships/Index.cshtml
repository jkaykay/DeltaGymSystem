@{
    ViewData["Title"] = "Memberships";
}

@section Styles {
  <link href="~/css/members/stylememberships.css" rel="stylesheet" asp-append-version="true"/>
}

  <!-- PAGE -->
  <div class="page">
    <div class="page-inner">

      <!-- Header -->
      <div class="page-header reveal">
        <p class="eyebrow">Pricing and Details</p>
        <h1>Choose Your Membership</h1>
      </div>

      <!-- Plans -->
      <div class="plans-grid reveal">

        <div class="plan-card">
          <div class="plan-name">Basic</div>
          <div class="plan-price">
            <span class="dollar">$</span><span class="amount">19.99</span><span class="period"> / mo</span>
          </div>
          <ul class="plan-features">
            <li>Access to GYM (Not in Peak)</li>
            <li>Locker room access</li>
            <li>1 free class per week</li>
            <li>Basic fitness assessments</li>
          </ul>
          <a asp-area="Member" asp-controller="Subscribe" asp-action="Index" class="plan-btn">Get started</a>
        </div>

        <div class="plan-card featured">
          <div class="popular-badge">MOST POPULAR</div>
          <div class="plan-name">Pro</div>
          <div class="plan-price">
            <span class="dollar">$</span><span class="amount">39.99</span><span class="period"> / mo</span>
          </div>
          <ul class="plan-features">
            <li>Anytime GYM access</li>
            <li>Unlimited classes</li>
            <li>Personal Locker</li>
            <li>Sauna and steam room free</li>
          </ul>
          <a asp-area="Member" asp-controller="Subscribe" asp-action="Index" class="plan-btn">Get started</a>
        </div>

      </div>

      <!-- FAQ -->
      <div class="faq-section reveal">
        <h2 class="faq-title">Common Questions</h2>
        <div class="faq-list">

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Can I switch plans anytime?</div>
            </div>
            <p class="faq-answer">Yes, you can upgrade or downgrade your plans at anytime. Changes take effect immediately.</p>
          </div>

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Is there a contract?</div>
            </div>
            <p class="faq-answer">No contracts. All plans are monthly based, and you can cancel anytime.</p>
          </div>

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Can I freeze my membership?</div>
            </div>
            <p class="faq-answer">Yes, you can freeze your membership for up to 3 months per year. Simply contact support to request a freeze.</p>
          </div>

        </div>
      </div>

      <!-- Ask Delta -->
      <div class="ask-delta-wrap reveal">
        <div class="ask-delta">
          <div class="ask-delta-title">"Ask DELTA"</div>
          <div class="ask-delta-input">
            <div class="ask-delta-avatar">
              <img src="images/Dumbell.png" alt="Delta Gyms Logo" class="nav-logo-img"/>
            </div>
            <input type="text" placeholder="What is your question ?" />
          </div>
        </div>
      </div>

    </div>
  </div>

