@using GymSystem.Shared.DTOs
@{
    ViewData["Title"] = "Memberships";
    var tiers = ViewBag.Tiers as List<TierDTO> ?? new List<TierDTO>();
    var featured = tiers.OrderByDescending(t => t.SubCount).FirstOrDefault();
    var deltaAnswer = ViewBag.DeltaAnswer as string;
    var deltaPrompt = ViewBag.DeltaPrompt as string;
}

@section Styles {
  <link href="~/css/members/stylememberships.css" rel="stylesheet" asp-append-version="true"/>
}

  <!-- PAGE -->
  <div class="page">
    <div class="page-inner">

      <!-- Header -->
      <div class="page-header reveal">
        <p class="eyebrow">Pricing and Details</p>
        <h1>Choose Your Membership</h1>
      </div>

      <!-- Plans -->
      <div class="plans-grid reveal">
        @if (tiers.Any())
        {
          @foreach (var tier in tiers)
          {
            var isFeatured = featured != null && tier.TierName == featured.TierName;
            <div class="plan-card @(isFeatured ? "featured" : "")">
              @if (isFeatured)
              {
                <div class="popular-badge">MOST POPULAR</div>
              }
              <div class="plan-name">@tier.TierName</div>
              <div class="plan-price">
                <span class="dollar">$</span><span class="amount">@tier.Price.ToString("F2")</span><span class="period"> / mo</span>
              </div>
              <ul class="plan-features">
                <li>Full gym access</li>
                <li>Locker room access</li>
                <li>@tier.SubCount active subscribers</li>
              </ul>
              <a asp-area="Member" asp-controller="Subscribe" asp-action="Index" asp-route-tier="@tier.TierName" class="plan-btn">Get started</a>
            </div>
          }
        }
        else
        {
          <p>Membership plans coming soon.</p>
        }
      </div>

      <!-- FAQ -->
      <div class="faq-section reveal">
        <h2 class="faq-title">Common Questions</h2>
        <div class="faq-list">

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Can I switch plans anytime?</div>
            </div>
            <p class="faq-answer">Yes, you can upgrade or downgrade your plans at any time. Changes take effect immediately.</p>
          </div>

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Is there a contract?</div>
            </div>
            <p class="faq-answer">No contracts. All plans are monthly based, and you can cancel anytime.</p>
          </div>

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Can I freeze my membership?</div>
            </div>
            <p class="faq-answer">Yes, you can freeze your membership for up to 3 months per year. Simply contact support to request a freeze.</p>
          </div>

        </div>
      </div>

      <!-- Ask Delta -->
        <div class="ask-delta-wrap">
            <div class="ask-delta">
                <div class="ask-delta-title">Ask DELTA</div>

                <form id="deltaChatForm">
                    @Html.AntiForgeryToken()

                    <div class="ask-delta-input">
                        <div class="ask-delta-avatar">
                            <img src="/images/LOGO.png" alt="DELTA" />
                        </div>

                        <textarea id="deltaMessage"
                                    placeholder="Ask about memberships, plans, or pricing..."
                                    rows="2"></textarea>
                    </div>

                    <div id="deltaLoading" class="ask-delta-loading" style="display:none;">
                        DELTA is thinking...
                    </div>

                    <div id="deltaReply" class="ask-delta-response" style="display:none;"></div>

                    <button type="button" id="deltaSendBtn" class="ask-delta-send">
                        Send
                    </button>
                </form>
            </div>
        </div>

    </div>
  </div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const messageBox = document.getElementById("deltaMessage");
            const replyBox = document.getElementById("deltaReply");
            const loadingText = document.getElementById("deltaLoading");
            const sendBtn = document.getElementById("deltaSendBtn");

            if (!messageBox || !replyBox || !loadingText || !sendBtn) return;

            sendBtn.addEventListener("click", async function () {
                const message = messageBox.value.trim();

                replyBox.style.display = "none";
                loadingText.style.display = "none";
                replyBox.innerText = "";

                if (!message) {
                    replyBox.style.display = "block";
                    replyBox.innerText = "Please type a question first.";
                    return;
                }

                loadingText.style.display = "block";
                sendBtn.disabled = true;

                try {
                    const response = await fetch("https://localhost:7183/api/LLM/chat", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify({ prompt: message })
                    });

                    const data = await response.json();

                    loadingText.style.display = "none";
                    sendBtn.disabled = false;
                    replyBox.style.display = "block";

                    if (!response.ok) {
                        replyBox.innerText = data.error || "Something went wrong while contacting DELTA.";
                        return;
                    }

                    replyBox.innerText = data.response ?? "Sorry, I couldn't get a response.";
                } catch (error) {
                    loadingText.style.display = "none";
                    sendBtn.disabled = false;

                    replyBox.style.display = "block";
                    replyBox.innerText = "Something went wrong while contacting DELTA.";
                    console.error("Chatbot error:", error);
                }
            });
        });
    </script>
}
