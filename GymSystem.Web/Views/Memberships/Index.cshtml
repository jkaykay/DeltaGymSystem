@{
    Layout= null;
}

@{
    ViewData["Title"] = "Memberships";
}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>DeltaGyms-Memberships</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"> 
  <link href="~/css/members/stylememberships.css" rel="stylesheet" />
</head>
<body>


  <!-- NAV  BAR-->
  <nav>
   <div class="nav-logo">
      <img src="~/images/logo.png" alt="Delta Gyms Logo" class="nav-logo-img"/>
    </div>
<ul class="nav-links">
      <li><a asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
      <li><a asp-area="" asp-controller="Classes" asp-action="Index">Classes</a></li>
      <li><a asp-area="" asp-controller="Memberships" asp-action="Index">Memberships</a></li>
      <li><a asp-area="Member" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
      <li><a asp-area="Member" asp-controller="MyProfile" asp-action="Index">MyProfile</a></li>
      <li><a asp-area="" asp-controller="Support" asp-action="Index">Support</a></li>
    </ul>
    <div class="nav-logout"><a href="#">Logout</a></div>
  </nav>

  <!-- PAGE -->
  <div class="page">
    <div class="page-inner">

      <!-- Header -->
      <div class="page-header reveal">
        <p class="eyebrow">Pricing and Details</p>
        <h1>Choose Your Membership</h1>
      </div>

      <!-- Plans -->
      <div class="plans-grid reveal">

        <div class="plan-card">
          <div class="plan-name">Basic</div>
          <div class="plan-price">
            <span class="dollar">$</span><span class="amount">19.99</span><span class="period"> / mo</span>
          </div>
          <ul class="plan-features">
            <li>Access to GYM (Not in Peak)</li>
            <li>Locker room access</li>
            <li>1 free class per week</li>
            <li>Basic fitness assessments</li>
          </ul>
          <a href="subscribe.html" class="plan-btn">Get started</a>
          <!-- <button class="plan-btn" onclick="window.location.href='subscribe.html'">Get started</button> -->
        </div>

        <div class="plan-card featured">
          <div class="popular-badge">MOST POPULAR</div>
          <div class="plan-name">Pro</div>
          <div class="plan-price">
            <span class="dollar">$</span><span class="amount">39.99</span><span class="period"> / mo</span>
          </div>
          <ul class="plan-features">
            <li>24/7 GYM access</li>
            <li>Unlimited classes</li>
            <li>Personal Locker</li>
            <li>Sauna and steam room free</li>
          </ul>
          <a href="subscribe.html" class="plan-btn">Get started</a>
          <!-- <button class="plan-btn" onclick="window.location.href='subscribe.html'">Get started</button> -->
        </div>

      </div>

      <!-- FAQ -->
      <div class="faq-section reveal">
        <h2 class="faq-title">Common Questions</h2>
        <div class="faq-list">

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Can I switch plans anytime?</div>
            </div>
            <p class="faq-answer">Yes, you can upgrade or downgrade your plans at anytime. Changes take effect immediately.</p>
          </div>

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Is there a contract?</div>
            </div>
            <p class="faq-answer">No contracts. All plans are monthly based, and you can cancel anytime.</p>
          </div>

          <div class="faq-item">
            <div class="faq-header">
              <div class="faq-icon">i</div>
              <div class="faq-question">Can I freeze my membership?</div>
            </div>
            <p class="faq-answer">Yes, you can freeze your membership for up to 3 months per year. Simply contact support to request a freeze.</p>
          </div>

        </div>
      </div>

      <!-- Ask Delta -->
      <div class="ask-delta-wrap reveal">
        <div class="ask-delta">
          <div class="ask-delta-title">"Ask DELTA"</div>
          <div class="ask-delta-input">
            <div class="ask-delta-avatar">
              <img src="images/Dumbell.png" alt="Delta Gyms Logo" class="nav-logo-img"/>
            </div>
            <input type="text" placeholder="What is your question ?" />
          </div>
        </div>
      </div>

    </div>
  </div>

   <!-- Scroll to Top Button -->
    <button class="scroll-top-btn" id="scrollTopBtn" onclick="window.scrollTo({top: 0, behavior: 'smooth'})">
  <i class="bi bi-arrow-up"></i>
</button>

  <script>
    // Sticky nav shadow
    const nav = document.querySelector('nav');
    window.addEventListener('scroll', () => {
      nav.style.boxShadow = window.scrollY > 10
        ? '0 4px 24px rgba(0,0,0,0.10)'
        : 'none';
    });

    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));


    // Show/hide scroll to top button
const scrollTopBtn = document.getElementById('scrollTopBtn');
window.addEventListener('scroll', () => {
  if (window.scrollY > 400) {
    scrollTopBtn.classList.add('visible');
  } else {
    scrollTopBtn.classList.remove('visible');
  }
});

  </script>
</body>
</html>
