  <!-- MEMBERSHIP OPS & HOURS -->
  <section class="ops-section reveal" id="membership-rules">
    <div class="ops-content">
      <span class="section-tag white">Membership</span>
      <h2 class="section-title white">Everything<br>You Need<br>To Know</h2>
      <ul class="ops-list">
        <li>No contracts ,cancel anytime with no fees</li>
        <li>Upgrade or downgrade your plan instantly</li>
        <li>Freeze your membership for up to 3 months per year (Talk to a staff member)</li>
        <li>Access to all group classes included in Pro plan</li>
        <li>Personal locker available on Pro membership</li>
        <li>Free fitness assessment when you join</li>
        <li>Student discount with valid ID</li>
      </ul>
    </div>
    <div class="ops-hours" id="opening-hours">
      <span class="section-tag" style="color: var(--accent);">Opening Hours</span>
      <h2 class="section-title white" style="margin-top: 6px;">When We're<br>Open</h2>
      <ul class="hours-list">
        <li class="hours-row"><span class="day">Monday-Friday</span><span class="time">All day</span></li>
        <li class="hours-row"><span class="day">Saturday</span><span class="time">06:00 – 22:00</span></li>
        <li class="hours-row"><span class="day">Sunday</span><span class="time">08:00 – 20:00</span></li>
        <li class="hours-row"><span class="day">Bank Holidays</span><span class="time closed">10:00 – 18:00</span></li>
        <li class="hours-row"><span class="day">Christmas Day and New Year's Day</span><span class="time closed">Closed</span></li>
      </ul>
    </div>
  </section>

