@{
    ViewData["Title"] = "About Us";
}

@section Styles {
  <link rel="stylesheet" href="~/css/members/about.css" asp-append-version="true"/>
}


  <!-- HERO -->
  <section class="hero">
    <div class="hero-ash-block"></div>
    <div class="hero-content reveal">
      <div class="hero-eyebrow">About Delta Gym</div>
      <h1 class="hero-title">Built For<br>Champions</h1>
      <p class="hero-desc">
        Delta Gym was founded with one mission — to build a space where every person,
        regardless of experience, feels empowered to push their limits. We combine 
        world-class facilities, expert coaching, and a community that lifts each other up.
      </p>
    </div>
  </section>

  <!-- STATS BAND -->
  <div class="stats-band reveal">
    <div class="stat-item">
    </div>
  </div>

  <!-- OUR STORY -->
  <section class="split-section reveal">
    <div class="split-content">
      <span class="section-tag">Our Story</span>
      <h2 class="section-title">Where It All<br>Started</h2>
      <p class="section-body">
        Delta Gym opened its doors in 2016 with a single gym floor and a vision to
        create more than just a place to work out. We wanted to build a community. 
        Over the years we've grown from a local gym into a full fitness hub, offering 
        classes, personal training, nutrition advice and more — all under one roof. 
        Every piece of equipment, every class, and every trainer has been chosen with 
        one thing in mind: your results.
      </p>
    </div>
    <div class="split-bg bg-red"></div>
  </section>

  <!-- WHY CHOOSE US -->
  <section class="why-section reveal">
    <span class="section-tag" style="color: var(--accent);">Why Delta Gym</span>
    <h2 class="section-title white" style="margin-top: 10px;">Why You Should<br>Choose Us</h2>
    <div class="why-grid">
      <div class="why-card">
        <div class="why-num">01</div>
        <h3>Expert Trainers</h3>
        <p>All our trainers are fully certified with years of hands-on experience. They tailor every session to your personal goals.</p>
      </div>
      <div class="why-card">
        <div class="why-num">02</div>
        <h3>World-Class Equipment</h3>
        <p>We invest in the latest gym equipment so you always have access to the best tools for your training.</p>
      </div>
      <div class="why-card">
        <div class="why-num">03</div>
        <h3>Community First</h3>
        <p>At Delta Gym, you're never alone. Our community keeps each other accountable, motivated, and moving forward.</p>
      </div>
      <div class="why-card">
        <div class="why-num">04</div>
        <h3>Flexible Membership</h3>
        <p>No contracts, no lock-ins. Upgrade, downgrade, or cancel your plan at any time — no questions asked (just talk to a staff member).</p>
      </div>
      <div class="why-card">
        <div class="why-num">05</div>
        <h3>All Fitness Levels</h3>
        <p>Whether you're just starting out or training for competition, we have classes and support for every type of fitness enthusiast.</p>
      </div>
      <div class="why-card">
        <div class="why-num">06</div>
        <h3>Clean & Safe Facility</h3>
        <p>Our facility is cleaned and sanitised throughout the day so you can focus on training in a safe environment.</p>
      </div>
    </div>
  </section>

  <!-- MACHINES -->
  <section class="machines-section reveal" id="machines-section">
    <span class="section-tag">Equipment</span>
    <h2 class="section-title" style="margin-top: 10px;">What We Got For YOU<br>In The Gym</h2>
    <div class="machines-list">
      <div class="machine-item"><span class="machine-dot"></span>Treadmills</div>
      <div class="machine-item"><span class="machine-dot"></span>Rowing Machines</div>
      <div class="machine-item"><span class="machine-dot"></span>Stationary Bikes</div>
      <div class="machine-item"><span class="machine-dot"></span>Cable Machines</div>
      <div class="machine-item"><span class="machine-dot"></span>Smith Machines</div>
      <div class="machine-item"><span class="machine-dot"></span>Leg Press</div>
      <div class="machine-item"><span class="machine-dot"></span>Lat Pulldown</div>
      <div class="machine-item"><span class="machine-dot"></span>Chest Press</div>
      <div class="machine-item"><span class="machine-dot"></span>Free Weights</div>
      <div class="machine-item"><span class="machine-dot"></span>Battle Ropes</div>
      <div class="machine-item"><span class="machine-dot"></span>Boxing Bags</div>
      <div class="machine-item"><span class="machine-dot"></span>Yoga & Stretch Area</div>
      <div class="machine-item"><span class="machine-dot"></span>Squat Racks</div>
      <div class="machine-item"><span class="machine-dot"></span>Elliptical Trainers</div>
      <div class="machine-item"><span class="machine-dot"></span>Functional Rig</div>
      <div class="machine-item"><span class="machine-dot"></span>Sauna & Steam Room</div>
    </div>
  </section>

  <!-- CLASS TYPES -->
  <section class="cards-section reveal">
    <div class="cards-header">
      <span class="section-tag">What We Offer</span>
      <h2 class="section-title" style="margin-top: 10px;">Classes For<br>Every Goal</h2>
    </div>
    <div class="cards-grid">
      @{ var classes = ViewBag.Classes as List<GymSystem.Shared.DTOs.ClassDTO>; }
      @if (classes != null && classes.Any())
      {
          var index = 0;
          foreach (var cls in classes)
          {
              <div class="info-card">
                  <div class="card-icon @(index % 2 == 0 ? "red" : "")">
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="12" cy="12" r="10" />
                          <path d="M8 12h8M12 8v8" />
                      </svg>
                  </div>
                  <h3>@cls.Subject</h3>
                  <p>
                      Taught by <strong>@cls.TrainerName</strong>
                      @if (cls.UpcomingSessionCount > 0)
                      {
                          <span> — @cls.UpcomingSessionCount session@(cls.UpcomingSessionCount != 1 ? "s" : "") available</span>
                      }
                  </p>
              </div>
              index++;
          }
      }
      else
      {
          <p style="color: #aaa; text-align: center; grid-column: 1 / -1;">No classes available at the moment.</p>
      }
    </div>
  </section>

  <!-- MEMBERSHIP OPS & HOURS -->
  <section class="ops-section reveal" id="membership-rules">
    <div class="ops-content">
      <span class="section-tag white">Membership</span>
      <h2 class="section-title white">Everything<br>You Need<br>To Know</h2>
      <ul class="ops-list">
        <li>No contracts, cancel anytime with no fees</li>
        <li>Upgrade or downgrade your plan instantly</li>
        <li>Freeze your membership for up to 3 months per year (Talk to a staff member)</li>
        <li>Access to all group classes included in Pro plan</li>
        <li>Personal locker available on Pro membership</li>
        <li>Free fitness assessment when you join</li>
        <li>Student discount with valid ID</li>
      </ul>
    </div>
    <div class="ops-hours" id="opening-hours">
      <span class="section-tag" style="color: var(--accent);">Opening Hours</span>
      <h2 class="section-title white" style="margin-top: 6px;">When We're<br>Open</h2>
      <ul class="hours-list">
        <li class="hours-row"><span class="day">Monday-Friday</span><span class="time">All day</span></li>
        <li class="hours-row"><span class="day">Saturday</span><span class="time">06:00 – 22:00</span></li>
        <li class="hours-row"><span class="day">Sunday</span><span class="time">08:00 – 20:00</span></li>
        <li class="hours-row"><span class="day">Bank Holidays</span><span class="time closed">10:00 – 18:00</span></li>
        <li class="hours-row"><span class="day">Christmas Day and New Year's Day</span><span class="time closed">Closed</span></li>
      </ul>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="contact-section reveal" id="contact-section">
    <span class="section-tag">Get In Touch</span>
    <h2 class="section-title" style="margin-top: 10px;">Contact Us</h2>
    <div class="contact-grid">
      <div class="contact-card">
        <div class="contact-icon">
          <i class="bi bi-geo-alt-fill"></i>
        </div>
        <span class="contact-label">Address</span>
        <span class="contact-value">12 Delta Street, London, United Kingdom</span>
      </div>
      <div class="contact-card">
        <div class="contact-icon">
         <i class="bi bi-telephone-fill"></i>
        </div>
        <span class="contact-label">Phone</span>
        <span class="contact-value">+44 000 0000 000</span>
      </div>
      <div class="contact-card">
        <div class="contact-icon">
         <i class="bi bi-envelope-fill"></i>
        </div>
        <span class="contact-label">Email</span>
        <span class="contact-value">hello@deltagym.com</span>
      </div>
      <div class="contact-card">
        <div class="contact-icon">
          <i class="bi bi-globe"></i>
        </div>
        <span class="contact-label">Social</span>
        <span class="contact-value">Delta Gym Socials</span>
      </div>
    </div>
  </section>

