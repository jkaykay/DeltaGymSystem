@{
    ViewData["Title"] = "About Us";
}

@section Styles {
  <link rel="stylesheet" href="~/css/members/about.css" asp-append-version="true"/>
}


  <!-- HERO -->
  <section class="hero">
    <div class="hero-ash-block"></div>
    <div class="hero-content reveal">
      <div class="hero-eyebrow">About DeltaGyms</div>
      <h1 class="hero-title">Built For<br>Champions</h1>
      <p class="hero-desc">
        DeltaGyms was founded with one mission — to build a space where every person, 
        regardless of experience, feels empowered to push their limits. We combine 
        world-class facilities, expert coaching, and a community that lifts each other up.
      </p>
    </div>
  </section>

  <!-- STATS BAND -->
  <div class="stats-band reveal">
    <div class="stat-item">
      <div class="stat-num">50+</div>
      <div class="stat-label">Classes Weekly</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">15K+</div>
      <div class="stat-label">Active Members</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">10+</div>
      <div class="stat-label">Expert Trainers</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">8</div>
      <div class="stat-label">Years Running</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">2</div>
      <div class="stat-label">Locations</div>
    </div>
  </div>

  <!-- OUR STORY -->
  <section class="split-section reveal">
    <div class="split-content">
      <span class="section-tag">Our Story</span>
      <h2 class="section-title">Where It All<br>Started</h2>
      <p class="section-body">
        DeltaGyms opened its doors in 2016 with a single gym floor and a vision to 
        create more than just a place to work out. We wanted to build a community. 
        Over the years we've grown from a local gym into a full fitness hub, offering 
        classes, personal training, nutrition advice and more — all under one roof. 
        Every piece of equipment, every class, and every trainer has been chosen with 
        one thing in mind: your results.
      </p>
    </div>
    <div class="split-bg bg-red"></div>
  </section>

  <!-- WHY CHOOSE US -->
  <section class="why-section reveal">
    <span class="section-tag" style="color: var(--accent);">Why DeltaGyms</span>
    <h2 class="section-title white" style="margin-top: 10px;">Why You Should<br>Choose Us</h2>
    <div class="why-grid">
      <div class="why-card">
        <div class="why-num">01</div>
        <h3>Expert Trainers</h3>
        <p>All our trainers are fully certified with years of hands-on experience. They tailor every session to your personal goals.</p>
      </div>
      <div class="why-card">
        <div class="why-num">02</div>
        <h3>World Class Equipment</h3>
        <p>We invest in the latest gym equipment so you always have access to the best tools for your training.</p>
      </div>
      <div class="why-card">
        <div class="why-num">03</div>
        <h3>Community First</h3>
        <p>At DeltaGyms, you're never alone. Our community keeps each other accountable, motivated and moving forward.</p>
      </div>
      <div class="why-card">
        <div class="why-num">04</div>
        <h3>Flexible Membership</h3>
        <p>No contracts, no lock ins. Upgrade, downgrade or cancel your plan any time no questions asked ( JustTalk to a staff member).</p>
      </div>
      <div class="why-card">
        <div class="why-num">05</div>
        <h3>All Fitness Levels</h3>
        <p>Whether you're just starting out or training for competition, we have classes and support for every type of fitness enthusiast.</p>
      </div>
      <div class="why-card">
        <div class="why-num">06</div>
        <h3>Clean & Safe Facility</h3>
        <p>Our facility is cleaned and sanitised throughout the day so you can focus on training in a safe environment.</p>
      </div>
    </div>
  </section>

  <!-- MACHINES -->
  <section class="machines-section reveal" id="machines-section">
    <span class="section-tag">Equipment</span>
    <h2 class="section-title" style="margin-top: 10px;">What We Got For YOU<br>In The Gym</h2>
    <div class="machines-list">
      <div class="machine-item"><span class="machine-dot"></span>Treadmills</div>
      <div class="machine-item"><span class="machine-dot"></span>Rowing Machines</div>
      <div class="machine-item"><span class="machine-dot"></span>Stationary Bikes</div>
      <div class="machine-item"><span class="machine-dot"></span>Cable Machines</div>
      <div class="machine-item"><span class="machine-dot"></span>Smith Machines</div>
      <div class="machine-item"><span class="machine-dot"></span>Leg Press</div>
      <div class="machine-item"><span class="machine-dot"></span>Lat Pulldown</div>
      <div class="machine-item"><span class="machine-dot"></span>Chest Press</div>
      <div class="machine-item"><span class="machine-dot"></span>Free Weights</div>
      <div class="machine-item"><span class="machine-dot"></span>Battle Ropes</div>
      <div class="machine-item"><span class="machine-dot"></span>Boxing Bags</div>
      <div class="machine-item"><span class="machine-dot"></span>Yoga & Stretch Area</div>
      <div class="machine-item"><span class="machine-dot"></span>Squat Racks</div>
      <div class="machine-item"><span class="machine-dot"></span>Elliptical Trainers</div>
      <div class="machine-item"><span class="machine-dot"></span>Functional Rig</div>
      <div class="machine-item"><span class="machine-dot"></span>Sauna & Steam Room</div>
    </div>
  </section>

