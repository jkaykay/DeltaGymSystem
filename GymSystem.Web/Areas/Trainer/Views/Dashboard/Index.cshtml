@{
    ViewData["Title"] = "Dashboard";
}

<section class="availability-card">
    <div class="availability-header">
        <h2>My Availability</h2>
        <button type="button" class="schedule-btn" onclick="toggleAvailabilityForm()">
            Edit Availability
        </button>
    </div>

    <div class="availability-preview">
        <div class="availability-row">
        </div>

        <div class="availability-row">
            <span>Tuesday</span>
            <span>9:00 AM - 1:00 PM</span>
        </div>

        <div class="availability-row">
            <span>Wednesday</span>
            <span>Unavailable</span>
        </div>
    </div>

    <div id="availabilityForm" class="availability-form">
        <h3>Edit Availability</h3>

        <div class="form-row">
            <label for="day">Day</label>
            <select id="day">
                <option>Monday</option>
                <option>Tuesday</option>
                <option>Wednesday</option>
                <option>Thursday</option>
                <option>Friday</option>
                <option>Saturday</option>
                <option>Sunday</option>
            </select>
        </div>

        <div class="form-row">
            <label for="startTime">Start Time</label>
            <input type="time" id="startTime" />
        </div>

        <div class="form-row">
            <label for="endTime">End Time</label>
            <input type="time" id="endTime" />
        </div>

        <div class="form-actions">
            <button type="button" class="save-btn">Save Changes</button>
            <button type="button" class="cancel-btn" onclick="toggleAvailabilityForm()">
                Cancel
            </button>
        </div>
    </div>
</section>

<br>
<br>

<section class="schedule-card dashboard-schedule">
    <div class="section-header">
        <h2>Today's Schedule</h2>
        <a asp-area="Trainer" asp-controller="Schedule" asp-action="Index" class="schedule-btn">
            View Full Schedule
        </a>
    </div>

    <div class="schedule-row">
        <span>class1</span>
        <span>8:00 AM</span>
    </div>

    <div class="schedule-row">
        <span>class2</span>
        <span>11:00 AM</span>
    </div>

    <div class="schedule-row">
        <span>class3</span>
        <span>6:00 PM</span>
    </div>
</section>

<script>
    function toggleAvailabilityForm() {
        const form = document.getElementById("availabilityForm");
        form.style.display = form.style.display === "block" ? "none" : "block";
    }
</script>

