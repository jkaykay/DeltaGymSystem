@model GymSystem.Web.Areas.Trainer.ViewModels.TrainerProfileViewModel
@{
    ViewData["Title"] = "Profile";
}

<main class="profile-page">
    <section class="profile-wrapper">
        <div class="profile-top">
            <div>
                <h1 class="profile-name">@Model.FullName</h1>
                <p class="profile-role">@Model.RoleLabel</p>
            </div>

            @if (!Model.IsEditing)
            {
                <a asp-area="Trainer" asp-controller="Profile" asp-action="Index" asp-route-edit="true" class="edit-button">
                    Edit Profile
                </a>
            }
        </div>

        <form asp-area="Trainer" asp-controller="Profile" asp-action="Index" method="post">
            @Html.AntiForgeryToken()

            <div class="profile-grid">
                <div class="profile-card">
                    <h2>Account Details</h2>

                    <div class="profile-item">
                        <span class="label">Username</span>
                        <span class="value">@Model.UserName</span>
                    </div>

                    <div class="profile-item">
                        <span class="label">Email</span>
                        @if (Model.IsEditing)
                        {
                            <input asp-for="Email" class="value" />
                            <span asp-validation-for="Email" class="field-validation-error"></span>
                        }
                        else
                        {
                            <span class="value">@Model.Email</span>
                        }
                    </div>

                    <div class="profile-item">
                        <span class="label">Phone Number</span>
                        @if (Model.IsEditing)
                        {
                            <div style="display:flex;align-items:center;gap:6px;">
                                <span style="font-weight:600;white-space:nowrap;">+44</span>
                                <input asp-for="PhoneNumber" class="value" placeholder="7911123456" />
                            </div>
                            <span asp-validation-for="PhoneNumber" class="field-validation-error"></span>
                        }
                        else
                        {
                            <span class="value">@(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "—" : "+44 " + Model.PhoneNumber)</span>
                        }
                    </div>
                </div>

                <div class="profile-card">
                    <h2>Professional Details</h2>

                    <div class="profile-item">
                        <span class="label">Trainer Title</span>
                        <span class="value">@Model.RoleLabel</span>
                    </div>

                    <div class="profile-item">
                        <span class="label">Gym Location</span>
                        <span class="value">@Model.GymLocation</span>
                    </div>
                </div>
            </div>

            @if (Model.IsEditing)
            {
                <div class="form-actions">
                    <button type="submit" class="edit-button">Save Changes</button>
                    <a asp-area="Trainer" asp-controller="Profile" asp-action="Index" class="edit-button">Cancel</a>
                </div>
            }
        </form>

        <div class="profile-card" style="margin-top:24px;">
            <h2>Security</h2>
            <div class="profile-item profile-item-row">
                <span class="label">Password</span>
                <a asp-area="Trainer" asp-controller="Password" asp-action="Index" class="edit-button">Change Password</a>
            </div>
        </div>
    </section>
</main>