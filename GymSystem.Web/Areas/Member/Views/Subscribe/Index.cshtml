@model GymSystem.Web.Areas.Member.ViewModels.SubscribeViewModel
@{
    ViewData["Title"] = "Subscribe";
}

@section Styles {
  <link rel="stylesheet" href="~/css/members/subscribe.css" asp-append-version="true"/>
}



  <!-- PAGE -->
  <div class="page">
    <div class="checkout-card">

      <!-- Banner -->
      <div class="card-banner">
        <a asp-area="" asp-controller="Memberships" asp-action="Index" class="back-link">
          <i class="bi bi-arrow-left"></i>
          Back
        </a>
        <div class="banner-label">Checkout</div>
        <div class="banner-title">Confirm Your Plan</div>
      </div>

      <!-- Body -->
      <div class="card-body">

        @if (TempData["ErrorMessage"] is string errorMsg)
        {
          <div style="background: #ff4444; color: white; padding: 0.75rem 1rem; border-radius: 8px; margin-bottom: 1rem;">
            @errorMsg
          </div>
        }

        <div class="summary-block">
          <div class="summary-row">
            <span class="s-label">Member Name</span>
            <span class="s-value">@Model.MemberName</span>
          </div>
          <div class="summary-row">
            <span class="s-label">Plan</span>
            <span class="s-value">
              <span class="membership-badge">@Model.TierName.ToUpper()</span>
            </span>
          </div>
          <div class="summary-row">
            <span class="s-label">Billing</span>
            <span class="s-value">Monthly</span>
          </div>
          <div class="summary-row">
            <span class="s-label">Amount</span>
            <span class="s-value price">$@Model.Price.ToString("F2")</span>
          </div>
        </div>

        <hr class="divider"/>

        <div class="total-row">
          <span class="t-label">Total Due Today</span>
          <span class="t-amount">$@Model.Price.ToString("F2")</span>
        </div>

        <form asp-area="Member" asp-controller="Subscribe" asp-action="ConfirmPayment" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden" name="tierName" value="@Model.TierName" />
          <input type="hidden" name="amount" value="@Model.Price" />
          <button type="submit" class="confirm-btn">
            CONFIRM PAYMENT
          </button>
        </form>

        <div class="secure-note">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          Secured &amp; encrypted payment
        </div>

      </div>
    </div>
  </div>

  <!-- SUCCESS OVERLAY -->
  <div class="overlay" id="overlay">
    <div class="success-modal">
      <div class="modal-top">
        <h2>Thanks!</h2>
      </div>
      <div class="modal-bottom">
        <div class="success-icon">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <h3>You're all set!</h3>
        <p>Your membership is now active. Welcome to Delta Gym — let's get to work!</p>

        <form asp-area="Member" asp-controller="MyProfile" asp-action="Index" method="get">
          <button type="submit" class="modal-btn">
            GO TO MY PROFILE
          </button>
        </form>

      </div>
    </div>
  </div>

  @if (TempData["SuccessMessage"] != null)
  {
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        document.getElementById('overlay').classList.add('show');
      });
    </script>
  }
