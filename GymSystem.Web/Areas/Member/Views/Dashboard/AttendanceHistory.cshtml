@model GymSystem.Web.Areas.Member.ViewModels.AttendanceHistoryViewModel
@{
    ViewData["Title"] = "Attendance History";
}

@section Styles {
  <link rel="stylesheet" href="~/css/members/dashboard.css" asp-append-version="true"/>
  <link rel="stylesheet" href="~/css/members/attendance-history.css" asp-append-version="true"/>
}

<div class="page">

  <!-- Header -->
  <div class="ah-header reveal">
    <a asp-area="Member" asp-controller="Dashboard" asp-action="Index" class="ah-back">
      <i class="bi bi-arrow-left"></i> Back to Dashboard
    </a>
    <h1>Attendance History</h1>
    <p>@Model.TotalCount total attendance record@(Model.TotalCount != 1 ? "s" : "")</p>
  </div>

  <!-- Table -->
  <div class="ah-card reveal">
    @if (Model.Attendances.Any())
    {
      <table class="ah-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Date</th>
            <th>Check In</th>
            <th>Check Out</th>
            <th>Duration</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          @{
            var rowNum = (Model.CurrentPage - 1) * 10;
          }
          @foreach (var a in Model.Attendances)
          {
            rowNum++;
            var duration = a.CheckOut.HasValue
                ? (a.CheckOut.Value - a.CheckIn)
                : (TimeSpan?)null;
            <tr>
              <td class="ah-row-num">@rowNum</td>
              <td>@a.CheckIn.ToLocalTime().ToString("dd MMM yyyy")</td>
              <td>@a.CheckIn.ToLocalTime().ToString("HH:mm")</td>
              <td>
                @if (a.CheckOut.HasValue)
                {
                  @a.CheckOut.Value.ToLocalTime().ToString("HH:mm")
                }
                else
                {
                  <span class="ah-badge ah-badge-active">In Gym</span>
                }
              </td>
              <td>
                @if (duration.HasValue)
                {
                  var h = (int)duration.Value.TotalHours;
                  var m = duration.Value.Minutes;
                  @(h > 0 ? $"{h}h {m}m" : $"{m}m")
                }
                else
                {
                  <text>—</text>
                }
              </td>
              <td>
                @if (a.InFlag)
                {
                  <span class="ah-badge ah-badge-active">Active</span>
                }
                else
                {
                  <span class="ah-badge ah-badge-done">Completed</span>
                }
              </td>
            </tr>
          }
        </tbody>
      </table>
    }
    else
    {
      <div class="ah-empty">
        <p>No attendance records found.</p>
      </div>
    }
  </div>

  <!-- Pagination -->
  @if (Model.TotalPages > 1)
  {
    <nav class="ah-pagination reveal">
      @if (Model.CurrentPage > 1)
      {
        <a asp-area="Member" asp-controller="Dashboard" asp-action="AttendanceHistory"
           asp-route-page="@(Model.CurrentPage - 1)" class="ah-page-link">
          <i class="bi bi-chevron-left"></i> Previous
        </a>
      }
      else
      {
        <span class="ah-page-link disabled"><i class="bi bi-chevron-left"></i> Previous</span>
      }

      <div class="ah-page-numbers">
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
          if (i == Model.CurrentPage)
          {
            <span class="ah-page-num active">@i</span>
          }
          else
          {
            <a asp-area="Member" asp-controller="Dashboard" asp-action="AttendanceHistory"
               asp-route-page="@i" class="ah-page-num">@i</a>
          }
        }
      </div>

      @if (Model.CurrentPage < Model.TotalPages)
      {
        <a asp-area="Member" asp-controller="Dashboard" asp-action="AttendanceHistory"
           asp-route-page="@(Model.CurrentPage + 1)" class="ah-page-link">
          Next <i class="bi bi-chevron-right"></i>
        </a>
      }
      else
      {
        <span class="ah-page-link disabled">Next <i class="bi bi-chevron-right"></i></span>
      }
    </nav>
  }

</div>
