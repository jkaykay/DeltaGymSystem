@{
    Layout = null;
}

@{
    ViewData["Title"] = "Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>DeltaGyms-Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="~/css/members/dashboard.css"/>
</head>
<body>

  <!-- NAV  BAR-->
  <nav>
   <div class="nav-logo">
      <img src="~/images/logo.png" alt="Delta Gyms Logo" class="nav-logo-img"/>
    </div>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/Classes">Classes</a></li>
      <li><a href="/Memberships">Memberships</a></li>
      <li><a href="/Dashboard" class="active">Dashboard</a></li>
      <li><a href="/MyProfile">MyProfile</a></li>
      <li><a href="/Support">Support</a></li>
    </ul>
    <div class="nav-logout"><a href="#">Logout</a></div>
  </nav>



  <div class="page">

    <!-- Welcome -->
    <div class="welcome reveal">
      <h1>WELCOME BACK "USERNAME"</h1>
      <p>Here's your fitness overview</p>
    </div>

    <!-- Stats -->
    <div class="stats-row reveal">
      <div class="stat-block">
        <label>Upcoming Classes</label>
        <div class="stat-box">
          <span class="val">Value</span>
          <span class="stat-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </span>
        </div>
      </div>

      <div class="stat-block">
        <label>Total Bookings</label>
        <div class="stat-box">
          <span class="val">Value</span>
          <span class="stat-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </span>
        </div>
      </div>

      <div class="stat-block">
        <label>Classes Attended</label>
        <div class="stat-box">
          <span class="val">Value</span>
        </div>
      </div>
    </div>

    <!-- Bottom Grid -->
    <div class="bottom-grid">

      <!-- Log History -->
      <div class="reveal">
        <h2 class="section-title">Log History</h2>
        <div class="log-card">
          <p class="log-month">Month is Showing here</p>
          <hr class="log-divider"/>
          <div class="log-list">

            <div class="log-item">
              <span class="log-star">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              </span>
              <div class="log-info">
                <div class="log-name">Friday afternoon workout</div>
                <div class="log-time">From 14.19 – 16.16</div>
              </div>
            </div>

            <div class="log-item">
              <span class="log-star">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              </span>
              <div class="log-info">
                <div class="log-name">Sunday morning workout</div>
                <div class="log-time">From 08.19 – 10.50</div>
              </div>
            </div>

            <div class="log-item">
              <span class="log-star">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              </span>
              <div class="log-info">
                <div class="log-name">Monday evening workout</div>
                <div class="log-time">From 22.23 – 23.52</div>
              </div>
            </div>

          </div>
        </div>
      </div>

      <!-- Payment History -->
      <div class="reveal">
        <h2 class="section-title">Payment History</h2>
        <div class="payment-list">

          <div class="payment-item">
            <span class="payment-month">March</span>
            <span class="payment-dash">-</span>
            <span class="payment-amount">$$$</span>
          </div>

          <div class="payment-item">
            <span class="payment-month">April</span>
            <span class="payment-dash">-</span>
            <span class="payment-amount">$$$</span>
          </div>

        </div>
      </div>

    </div>
  </div>

  <script>
    // Nav shadow on scroll
    const nav = document.querySelector('nav');
    window.addEventListener('scroll', () => {
      nav.style.boxShadow = window.scrollY > 10
        ? '0 4px 24px rgba(0,0,0,0.08)'
        : 'none';
    });

    // Scroll reveal — stagger each item
    const items = document.querySelectorAll('.reveal');
    items.forEach((el, i) => {
      el.style.transitionDelay = `${i * 80}ms`;
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.08 });
    items.forEach(el => observer.observe(el));
  </script>
</body>
</html>

