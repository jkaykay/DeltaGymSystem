@model GymSystem.Web.Areas.Member.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

@section Styles {
  <link rel="stylesheet" href="~/css/members/dashboard.css" asp-append-version="true"/>
}



  <div class="page">

    <!-- Welcome -->
    <div class="welcome reveal">
      <h1>WELCOME BACK "@Model.Username"</h1>
      <p>Here's your fitness overview</p>
    </div>

    <!-- Stats -->
    <div class="stats-row reveal">
      <div class="stat-block upcoming-block">
        <label>Upcoming Bookings <span class="attendance-count">@Model.TotalBookings bookings</span></label>
        @if (Model.UpcomingBookings.Any())
        {
          <div class="upcoming-list">
            @foreach (var booking in Model.UpcomingBookings)
            {
              <div class="upcoming-item">
                <span class="upcoming-icon">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                  </svg>
                </span>
                <div class="upcoming-info">
                  <div class="upcoming-name">@booking.Subject</div>
                  <div class="upcoming-time">@booking.SessionStart.ToLocalTime().ToString("ddd dd MMM, HH:mm") &ndash; @booking.SessionEnd.ToLocalTime().ToString("HH:mm")</div>
                </div>
              </div>
            }
          </div>
        }
        else
        {
          <div class="stat-box">
            <span class="val">No upcoming bookings</span>
          </div>
        }
        <a asp-area="Member" asp-controller="Dashboard" asp-action="BookingHistory" class="view-more-link">View All &raquo;</a>
      </div>
    </div>

    <!-- Bottom Grid -->
    <div class="bottom-grid">

      <!-- Visit History -->
      <div class="reveal">
        <h2 class="section-title">Visit History <span class="attendance-count">@Model.TotalAttendances visits</span></h2>
        <div class="log-card">
          @if (Model.LogHistory.Any())
          {
            <p class="log-month">@Model.LogHistory.First().CheckIn.ToString("MMMM yyyy")</p>
            <hr class="log-divider"/>
            <div class="log-list">
              @foreach (var log in Model.LogHistory)
              {
                <div class="log-item">
                  <span class="log-star">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                  </span>
                  <div class="log-info">
                    <div class="log-name">@log.CheckIn.ToLocalTime().ToString("dd MMM") &ndash; @log.CheckIn.ToString("dddd") &ndash; @if (log.CheckOut.HasValue)
{<text>@((log.CheckOut.Value - log.CheckIn).TotalHours.ToString("0.#")) hrs</text>}
else
{<text>In progress</text>}</div>
                    <div class="log-time">
                      @log.CheckIn.ToLocalTime().ToString("HH:mm")
                      @if (log.CheckOut.HasValue)
                      {
                        <text> – @log.CheckOut.Value.ToLocalTime().ToString("HH:mm")</text>
                      }
                    </div>
                  </div>
                </div>
              }
            </div>
          }
          else
          {
            <p class="log-month">No visits yet</p>
          }
        </div>
        <a asp-area="Member" asp-controller="Dashboard" asp-action="AttendanceHistory" class="view-more-link">View More &raquo;</a>
      </div>

      <!-- Payment History -->
      <div class="reveal">
        <h2 class="section-title">Payment History</h2>
        <div class="payment-list">
          @if (Model.PaymentHistory.Any())
          {
            @foreach (var payment in Model.PaymentHistory)
            {
              <div class="payment-item">
                <span class="payment-month">@payment.PaymentDate.ToString("MMMM yyyy")</span>
                <span class="payment-dash">-</span>
                <span class="payment-amount">$@payment.Amount.ToString("F2")</span>
              </div>
            }
          }
          else
          {
            <div class="payment-item">
              <span class="payment-month">No payments yet</span>
            </div>
          }
        </div>
        <a asp-area="Member" asp-controller="Dashboard" asp-action="PaymentHistory" class="view-more-link">View More &raquo;</a>
      </div>

    </div>
  </div>

