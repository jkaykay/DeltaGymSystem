@model PaymentHistoryViewModel
@{
    ViewData["Title"] = "Payment History";
}

@section Styles {
  <link rel="stylesheet" href="~/css/members/dashboard.css" asp-append-version="true"/>
}

<div class="page">

  <a asp-area="Member" asp-controller="Dashboard" asp-action="Index" class="back-link reveal">
    <i class="bi bi-arrow-left"></i> Back to Dashboard
  </a>

  <h1 class="history-page-title reveal">PAYMENT HISTORY</h1>
  <p class="history-subtitle reveal">@Model.TotalCount total payment@(Model.TotalCount != 1 ? "s" : "")</p>

  <div class="history-list reveal">
    @if (Model.Payments.Any())
    {
      @foreach (var payment in Model.Payments)
      {
        <div class="history-item">
          <div class="history-date">@payment.PaymentDate.ToLocalTime().ToString("dd MMM yyyy")</div>
          <div class="history-details">
            <div class="history-subject">@payment.PaymentDate.ToString("MMMM yyyy")</div>
          </div>
          <div class="history-status">
            <span class="payment-amount">$@payment.Amount.ToString("F2")</span>
          </div>
        </div>
      }
    }
    else
    {
      <p class="history-empty">No payments yet.</p>
    }
  </div>

  @if (Model.TotalPages > 1)
  {
    <div class="pagination reveal">
      @if (Model.CurrentPage > 1)
      {
        <a asp-action="PaymentHistory" asp-route-page="@(Model.CurrentPage - 1)" class="page-link">&laquo; Previous</a>
      }
      <span class="page-info">Page @Model.CurrentPage of @Model.TotalPages</span>
      @if (Model.CurrentPage < Model.TotalPages)
      {
        <a asp-action="PaymentHistory" asp-route-page="@(Model.CurrentPage + 1)" class="page-link">Next &raquo;</a>
      }
    </div>
  }

</div>

<script>
  const items = document.querySelectorAll('.reveal');
  items.forEach((el, i) => {
    el.style.transitionDelay = `${i * 80}ms`;
  });
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  items.forEach(el => observer.observe(el));
</script>
