@model ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

@section Styles {
  <link rel="stylesheet" href="~/css/members/myprofile.css" asp-append-version="true"/>
}


<div class="page">

  <!-- SUCCESS MESSAGE -->
  @if (TempData["SuccessMessage"] is string msg)
  {
      <div class="alert alert-success">@msg</div>
  }

  <!-- EDIT BUTTON -->
  <div class="edit-row">
    <button type="button" class="edit-btn" onclick="enableEdit()">
      <i class="bi bi-pencil-square"></i>
    </button>
  </div>

  <h1 class="profile-page-title">MY PROFILE</h1>

  <!-- TOP INFO -->
  <div class="profile-grid">

    <div>
      <div class="user-name">@Model.UserName</div>

      <div class="full-name-label">@Model.FirstName @Model.LastName</div>

      @if (Model.JoinDate.HasValue)
      {
        <div class="membership-badge">Member since @Model.JoinDate.Value.ToString("MMM yyyy")</div>
      }
    </div>
  </div>

  <!-- FORM START -->
  <form asp-area="Member" asp-controller="MyProfile" asp-action="Update" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="UserName" />
    <input type="hidden" asp-for="JoinDate" />
    <input type="hidden" asp-for="Active" />

    <div class="fields-section">

      <div class="fields-row">
        <div class="field-group">
          <span class="field-label">First Name</span>
          <input asp-for="FirstName" class="field-box" readonly />
          <span asp-validation-for="FirstName" class="error"></span>
        </div>

        <div class="field-group">
          <span class="field-label">Last Name</span>
          <input asp-for="LastName" class="field-box" readonly />
          <span asp-validation-for="LastName" class="error"></span>
        </div>
      </div>

      <div class="fields-row">
        <div class="field-group">
          <span class="field-label">Email</span>
          <input asp-for="Email" class="field-box" readonly />
          <span asp-validation-for="Email" class="error"></span>
        </div>
      </div>

      <!-- ACTION BUTTONS -->
      <div class="btn-row" style="display:none;">
        <button type="submit" class="save-btn">Save Changes</button>
        <button type="button" class="cancel-btn" onclick="cancelEdit()">Cancel</button>
      </div>

    </div>
  </form>

</div>

<!-- SCRIPTS -->
<script>
function enableEdit() {
    const inputs = document.querySelectorAll('.field-box');
    inputs.forEach(input => {
        input.dataset.original = input.value;
        input.removeAttribute('readonly');
    });
    document.querySelector('.btn-row').style.display = 'flex';
}

function cancelEdit() {
    const inputs = document.querySelectorAll('.field-box');
    inputs.forEach(input => {
        input.value = input.dataset.original;
        input.setAttribute('readonly', '');
    });
    document.querySelector('.btn-row').style.display = 'none';
}
</script>

@section Scripts {
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}