@model ProfileViewModel

@{
    Layout = null;
    ViewData["Title"] = "My Profile";
}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>@ViewData["Title"]</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="~/css/members/myprofile.css" asp-append-version="true"/>
</head>

<body>

<!-- NAV BAR -->
<nav>
  <div class="nav-logo">
    <img src="~/images/logo.png" alt="Delta Gyms Logo" class="nav-logo-img"/>
  </div>
  <ul class="nav-links">
    <li><a asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
    <li><a asp-area="" asp-controller="Classes" asp-action="Index">Classes</a></li>
    <li><a asp-area="" asp-controller="Memberships" asp-action="Index">Memberships</a></li>
    <li><a asp-area="Member" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
    <li><a asp-area="Member" asp-controller="MyProfile" asp-action="Index" class="active">MyProfile</a></li>
    <li><a asp-area="" asp-controller="About" asp-action="Index">About</a></li>
  </ul>

  @if (User.Identity != null && User.Identity.IsAuthenticated)
  {
      <form asp-area="Member" asp-controller="Login" asp-action="Logout" method="post" class="nav-logout">
          @Html.AntiForgeryToken()
          <button type="submit" class="logout-btn">Logout</button>
      </form>
  }
  else
  {
      <div class="nav-logout">
          <a asp-area="Member" asp-controller="Login" asp-action="Index">Login</a>
      </div>
  }
</nav>

<div class="page">

  <!-- SUCCESS MESSAGE -->
  @if (TempData["SuccessMessage"] is string msg)
  {
      <div class="alert alert-success" id="successAlert">@msg</div>
  }

  <!-- EDIT BUTTON -->
  <div class="edit-row">
    <button type="button" class="edit-btn" onclick="enableEdit()">
      <i class="bi bi-pencil-square"></i>
    </button>
  </div>

  <h1 class="profile-page-title">MY PROFILE</h1>

  <!-- TOP INFO -->
  <div class="profile-grid">
    <div>
      <div class="user-name">@Model.UserName</div>
      <div class="membership-badge">@Model.MembershipName</div>
      <div class="membership-price">
        <span class="dollar">$</span>
        <span class="amount">@Model.MembershipPrice</span>
      </div>
      <div class="full-name-label">@Model.FullName</div>
    </div>

    <div class="member-code-card">
  <div class="member-code-title">MEMBER QR</div>
  <div class="member-code-body">
    @if (!string.IsNullOrEmpty(Model.QrCodeBase64))
    {
        <div class="qr-wrap">
        <img src="data:image/png;base64,@Model.QrCodeBase64" 
        alt="Member QR Code" class="qr-code" 
        style="width: 120px; height: 120px; object-fit: contain; margin: -20px; margin-left: 3px;"/>
        </div>
    }
  </div>
</div>
  </div>

  <!-- FORM -->
  <form asp-area="Member" asp-controller="MyProfile" asp-action="Update" method="post">
    @Html.AntiForgeryToken()

    <!-- Hidden fields so they survive the POST -->
    <input type="hidden" asp-for="UserId" />
    <input type="hidden" asp-for="UserName" />
    <input type="hidden" asp-for="FullName" />
    <input type="hidden" asp-for="MembershipName" />
    <input type="hidden" asp-for="MembershipPrice" />

    <div class="fields-section">
      <div class="fields-row">

        <div class="field-group">
          <span class="field-label">First Name</span>
          <input asp-for="FirstName" class="field-box" readonly />
          <span asp-validation-for="FirstName" class="error"></span>
        </div>

        <div class="field-group">
          <span class="field-label">Last Name</span>
          <input asp-for="LastName" class="field-box" readonly />
          <span asp-validation-for="LastName" class="error"></span>
        </div>

      </div>

      <div class="fields-row">

        <div class="field-group">
          <span class="field-label">Email</span>
          <input asp-for="Email" class="field-box" readonly />
          <span asp-validation-for="Email" class="error"></span>
        </div>

      </div>

      <button type="submit" class="save-btn" style="display:none;">
        Save Changes
      </button>
    </div>
  </form>

</div>

<script>
function enableEdit() {
    document.querySelectorAll('.field-box').forEach(i => i.removeAttribute('readonly'));
    document.querySelector('.save-btn').style.display = 'inline-block';

}
    const successAlert = document.getElementById('successAlert');
    if (successAlert) {
        setTimeout(() => {
            successAlert.style.transition = 'opacity 0.5s ease';
            successAlert.style.opacity = '0';
            setTimeout(() => successAlert.remove(),500);
        }, 3000);
    }


</script> 

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>