@model ProfileViewModel

@{
    Layout = null;
}

@{
    ViewData["Title"] = "My Profile";
} 

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>@ViewData["Title"]</title>

  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="~/css/members/myprofile.css" asp-append-version="true"/>
</head>

<body>

<!-- NAV  BAR-->
  <nav>
   <div class="nav-logo">
      <img src="~/images/logo.png" alt="Delta Gyms Logo" class="nav-logo-img"/>
    </div>
    <ul class="nav-links">
      <li><a asp-area="" asp-controller="Home" asp-action="Index" class="active">Home</a></li>
      <li><a asp-area="" asp-controller="Classes" asp-action="Index">Classes</a></li>
      <li><a asp-area="" asp-controller="Memberships" asp-action="Index">Memberships</a></li>
      <li><a asp-area="Member" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
      <li><a asp-area="Member" asp-controller="MyProfile" asp-action="Index">MyProfile</a></li>
      <li><a asp-area="" asp-controller="About" asp-action="Index">About</a></li>
    </ul>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <form asp-area="Member" asp-controller="Login" asp-action="Logout" method="post" class="nav-logout">
        @Html.AntiForgeryToken()
        <button type="submit" class="logout-btn">
            Logout
        </button>
    </form>
}
else
{
    <div class="nav-logout">
        <a asp-area="Member" asp-controller="Login" asp-action="Index" >
            Login
        </a>
    </div>
}
  </nav>


<div class="page">

  <!-- SUCCESS MESSAGE -->
  @if (TempData["SuccessMessage"] is string msg)
  {
      <div class="alert alert-success">@msg</div>
  }

  <!-- EDIT BUTTON -->
  <div class="edit-row">
    <button type="button" class="edit-btn" onclick="enableEdit()">
      <i class="bi bi-pencil-square"></i>
    </button>
  </div>

  <h1 class="profile-page-title">MY PROFILE</h1>

  <!-- TOP INFO -->
  <div class="profile-grid">

    <div>
      <div class="user-name">@Model.UserName</div>
      <div class="membership-badge">@Model.MembershipName</div>

      <div class="membership-price">
        <span class="dollar">$</span>
        <span class="amount">@Model.MembershipPrice</span>
      </div>

      <div class="full-name-label">@Model.FullName</div>
    </div>

    <div class="member-code-card">
      <div class="member-code-title">MEMBER CODE</div>
      <div class="member-code-body">

        <div class="qr-wrap">
          <!-- keep your SVG -->
        </div>

        <div class="member-code-info">
          <div class="code-value">@Model.MemberCode</div>
          <div class="code-hint">Show at front desk if needed</div>
        </div>
      </div>
    </div>
  </div>

  <!-- FORM START -->
  <form asp-area="Member" asp-controller="MyProfile" asp-action="Update" method="post">
    @Html.AntiForgeryToken()

    <div class="fields-section">

      <div class="fields-row">
        <div class="field-group">
          <span class="field-label">Telephone</span>
          <input asp-for="Telephone" class="field-box" readonly />
          <span asp-validation-for="Telephone" class="error"></span>
        </div>

        <div class="field-group">
          <span class="field-label">Email</span>
          <input asp-for="Email" class="field-box" readonly />
          <span asp-validation-for="Email" class="error"></span>
        </div>
      </div>

      <div class="fields-row">
        <div class="field-group">
          <span class="field-label">Emergency Contact</span>
          <input asp-for="EmergencyContact" class="field-box" readonly />
          <span asp-validation-for="EmergencyContact" class="error"></span>
        </div>

        <div class="field-group">
          <span class="field-label">Current Weight</span>
          <input asp-for="Weight" class="field-box" readonly />
          <span asp-validation-for="Weight" class="error"></span>
        </div>
      </div>

      <!-- SAVE BUTTON -->
      <button type="submit" class="save-btn" style="display:none;">
        Save Changes
      </button>

    </div>
  </form>

</div>

<!-- SCRIPTS -->
<script>
function enableEdit() {
    const inputs = document.querySelectorAll('.field-box');
    inputs.forEach(input => input.removeAttribute('readonly'));

    document.querySelector('.save-btn').style.display = 'inline-block';
}
</script>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>