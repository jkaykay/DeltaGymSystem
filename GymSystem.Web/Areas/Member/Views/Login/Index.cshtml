@model GymSystem.Web.Areas.Member.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>@ViewData["Title"]</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="~/css/members/login.css"/>
</head>
<body>


<section id="login" class="min-vh-100 d-flex align-items-center justify-content-center">
    <div class="container-user">
        
        <h2>Welcome Back</h2>

        <!-- Success message -->
        @if (TempData["SuccessMessage"] is string msg)
        {
            <div class="alert alert-success">@msg</div>
        }

        <!-- Error summary -->
        <div asp-validation-summary="ModelOnly" class="error mb-2"></div>

        <form asp-action="Login" asp-controller="Account" asp-area="Member" method="post">
            
            @Html.AntiForgeryToken()

            <input asp-for="ReturnUrl" type="hidden"/>

            <!-- Username / Email -->
            <input asp-for="EmailOrUserName" 
                   placeholder="Email or Username" 
                   class="form-control mb-2"/>
            <span asp-validation-for="EmailOrUserName" class="error"></span>

            <!-- Password -->
            <input asp-for="Password" 
                   type="password" 
                   placeholder="Password" 
                   class="form-control mb-2"/>
            <span asp-validation-for="Password" class="error"></span>

            <!-- Submit -->
            <button type="submit" class="login-btn w-100 mt-2">
                Login
            </button>

        </form>

        <!-- Register link -->
        <div class="mt-4 text-center">
            <p class="text-muted">
                Don't have an account?
                <a asp-action="Register" asp-controller="Account" asp-area="Member">
                    Register
                </a>
            </p>
        </div>

    </div>
</section>

<!-- Scripts -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>