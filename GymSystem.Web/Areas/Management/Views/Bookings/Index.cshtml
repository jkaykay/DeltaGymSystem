@model PagedResult<BookingDTO>

@{
    ViewData["Title"] = "Manage Bookings";

    var search = ViewData["Search"] as string;
    var dateFrom = ViewData["DateFrom"] as DateTime?;
    var dateTo = ViewData["DateTo"] as DateTime?;
    var sortBy = ViewData["SortBy"] as string;
    var sortDir = ViewData["SortDir"] as string;
}

<div class="page-header">
    <h1 class="page-header-title">🎫 Bookings</h1>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">➕ Add Booking</a>
        <span class="record-count">@Model.TotalCount total</span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error" role="alert">
        @TempData["Error"]
    </div>
}

<div class="dashboard-card" style="margin-bottom: 16px;">
    <div class="card-header">
        <h5>Search &amp; Filter</h5>
    </div>
    <form method="get" asp-action="Index" class="search-bar">
        <div class="search-bar-row">
            <div class="form-group">
                <label for="search">Search</label>
                <input type="text" id="search" name="search" class="form-control"
                       placeholder="Member name, class subject…" value="@search" />
            </div>
            <div class="form-group">
                <label for="dateFrom">Session From</label>
                <input type="date" id="dateFrom" name="dateFrom" class="form-control"
                       value="@dateFrom?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group">
                <label for="dateTo">Session To</label>
                <input type="date" id="dateTo" name="dateTo" class="form-control"
                       value="@dateTo?.ToString("yyyy-MM-dd")" />
            </div>
        </div>
        <div class="search-bar-row">
            <div class="form-group">
                <label for="sortBy">Sort By</label>
                <select id="sortBy" name="sortBy" class="form-control">
                    <option value="">Booked On</option>
                    <option value="member" selected="@(sortBy == "member")">Member</option>
                    <option value="subject" selected="@(sortBy == "subject")">Class</option>
                    <option value="session" selected="@(sortBy == "session")">Session Start</option>
                </select>
            </div>
            <div class="form-group">
                <label for="sortDir">Direction</label>
                <select id="sortDir" name="sortDir" class="form-control">
                    <option value="asc" selected="@(sortDir == "asc")">Ascending</option>
                    <option value="desc" selected="@(sortDir == "desc")">Descending</option>
                </select>
            </div>
            <div class="form-group search-bar-actions">
                <label>&nbsp;</label>
                <div class="table-actions">
                    <button type="submit" class="btn btn-primary">🔍 Search</button>
                    <a asp-action="Index" class="btn btn-secondary">✕ Clear</a>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="dashboard-card">
    <div class="card-header">
        <h5>Booking Records</h5>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Member</th>
                <th>Class</th>
                <th>Room</th>
                <th>Session Start</th>
                <th>Session End</th>
                <th>Booked On</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model.Items)
            {
                <tr>
                    <td>@booking.BookingId</td>
                    <td>@booking.UserName</td>
                    <td>@booking.Subject</td>
                    <td>Room @booking.RoomNumber</td>
                    <td>@booking.SessionStart.ToString("MMM dd, yyyy HH:mm")</td>
                    <td>@booking.SessionEnd.ToString("MMM dd, yyyy HH:mm")</td>
                    <td>@booking.BookDate.ToString("MMM dd, yyyy")</td>
                    <td>
                        <div class="table-actions">
                            <a asp-action="Details" asp-route-id="@booking.BookingId" class="btn btn-secondary btn-sm">Details</a>
                            <form asp-action="Delete" asp-route-id="@booking.BookingId" method="post"
                                  onsubmit="return confirm('Are you sure you want to cancel this booking?');">
                                <button type="submit" class="btn btn-danger btn-sm">Cancel</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <p>No bookings found.</p>
        </div>
    }
    <div class="pagination-wrapper">
        <partial name="_Pagination" model="Model" />
    </div>
</div>