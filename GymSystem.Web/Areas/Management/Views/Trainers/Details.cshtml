@model UserDTO

@{
    ViewData["Title"] = "Trainer Details";
}

<div class="page-header">
    <h1 class="page-header-title">Trainer Details</h1>
    <a asp-action="Index" class="btn btn-secondary">← Back to List</a>
</div>

<div class="detail-card">
    <div class="card-header">
        <h5>Trainer Profile</h5>
    </div>
    <div class="detail-body">
        <p class="detail-name">@Model.FirstName @Model.LastName</p>
        <dl class="detail-dl">
            <dt>Email</dt>
            <dd>@Model.Email</dd>

            <dt>Username</dt>
            <dd>@Model.UserName</dd>

            <dt>Employee ID</dt>
            <dd>@(Model.EmployeeId ?? "—")</dd>

            <dt>Branch</dt>
            <dd>@(Model.BranchId?.ToString() ?? "—")</dd>

            <dt>Hire Date</dt>
            <dd>@(Model.HireDate?.ToString("MMMM dd, yyyy") ?? "—")</dd>
        </dl>
    </div>
    <div class="detail-actions">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        }
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>