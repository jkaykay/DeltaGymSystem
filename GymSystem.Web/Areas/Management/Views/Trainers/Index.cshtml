@model PagedResult<UserDTO>

@{
    ViewData["Title"] = "Manage Trainers";

    var search = ViewData["Search"] as string;
    var hiredFrom = ViewData["HiredFrom"] as DateTime?;
    var hiredTo = ViewData["HiredTo"] as DateTime?;
    var sortBy = ViewData["SortBy"] as string;
    var sortDir = ViewData["SortDir"] as string;
}

<div class="page-header">
    <h1 class="page-header-title">🏋️ Trainers</h1>
    <div class="page-actions">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">➕ Add Trainer</a>
        }
        <span class="record-count">@Model.TotalCount total</span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error" role="alert">
        @TempData["Error"]
    </div>
}

<div class="dashboard-card" style="margin-bottom: 16px;">
    <div class="card-header">
        <h5>Search &amp; Filter</h5>
    </div>
    <form method="get" asp-action="Index" class="search-bar">
        <div class="search-bar-row">
            <div class="form-group">
                <label for="search">Search</label>
                <input type="text" id="search" name="search" class="form-control"
                       placeholder="Name, email, employee ID…" value="@search" />
            </div>
            <div class="form-group">
                <label for="hiredFrom">Hired From</label>
                <input type="date" id="hiredFrom" name="hiredFrom" class="form-control"
                       value="@hiredFrom?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group">
                <label for="hiredTo">Hired To</label>
                <input type="date" id="hiredTo" name="hiredTo" class="form-control"
                       value="@hiredTo?.ToString("yyyy-MM-dd")" />
            </div>
        </div>
        <div class="search-bar-row">
            <div class="form-group">
                <label for="sortBy">Sort By</label>
                <select id="sortBy" name="sortBy" class="form-control">
                    <option value="">Hire Date</option>
                    <option value="firstName" selected="@(sortBy == "firstName")">First Name</option>
                    <option value="lastName" selected="@(sortBy == "lastName")">Last Name</option>
                    <option value="email" selected="@(sortBy == "email")">Email</option>
                    <option value="employeeId" selected="@(sortBy == "employeeId")">Employee ID</option>
                </select>
            </div>
            <div class="form-group">
                <label for="sortDir">Direction</label>
                <select id="sortDir" name="sortDir" class="form-control">
                    <option value="asc" selected="@(sortDir == "asc")">Ascending</option>
                    <option value="desc" selected="@(sortDir == "desc")">Descending</option>
                </select>
            </div>
            <div class="form-group search-bar-actions">
                <label>&nbsp;</label>
                <div class="table-actions">
                    <button type="submit" class="btn btn-primary">🔍 Search</button>
                    <a asp-action="Index" class="btn btn-secondary">✕ Clear</a>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="dashboard-card">
    <div class="card-header">
        <h5>Trainer Directory</h5>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Employee ID</th>
                <th>Branch</th>
                <th>Hire Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var trainer in Model.Items)
            {
                <tr>
                    <td>@trainer.FirstName @trainer.LastName</td>
                    <td>@trainer.Email</td>
                    <td>@(trainer.PhoneNumber ?? "—")</td>
                    <td>@(trainer.EmployeeId ?? "—")</td>
                    <td>@(trainer.BranchId?.ToString() ?? "—")</td>
                    <td>@(trainer.HireDate?.ToString("MMM dd, yyyy") ?? "—")</td>
                    <td>
                        <div class="table-actions">
                            <a asp-action="Details" asp-route-id="@trainer.Id" class="btn btn-secondary btn-sm">Details</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@trainer.Id" class="btn btn-secondary btn-sm">Edit</a>
                                <form asp-action="Delete" asp-route-id="@trainer.Id" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this trainer?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <p>No trainers found.</p>
        </div>
    }
    <div class="pagination-wrapper">
        <partial name="_Pagination" model="Model" />
    </div>
</div>