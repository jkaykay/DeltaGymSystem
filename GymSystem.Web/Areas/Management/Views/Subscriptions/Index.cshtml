@model PagedResult<SubscriptionDTO>
@using GymSystem.Shared.Enums

@{
    ViewData["Title"] = "Manage Subscriptions";

    var search = ViewData["Search"] as string;
    var state = ViewData["State"] as int?;
    var tierName = ViewData["TierName"] as string;
    var startFrom = ViewData["StartFrom"] as DateTime?;
    var startTo = ViewData["StartTo"] as DateTime?;
    var sortBy = ViewData["SortBy"] as string;
    var sortDir = ViewData["SortDir"] as string;

    var tiers = ViewBag.Tiers as List<TierDTO> ?? new List<TierDTO>();
}

<div class="page-header">
    <h1 class="page-header-title">📄 Subscriptions</h1>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">➕ Add Subscription</a>
        <span class="record-count">@Model.TotalCount total</span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error" role="alert">
        @TempData["Error"]
    </div>
}

<div class="dashboard-card" style="margin-bottom: 16px;">
    <div class="card-header">
        <h5>Search &amp; Filter</h5>
    </div>
    <form method="get" asp-action="Index" class="search-bar">
        <div class="search-bar-row">
            <div class="form-group">
                <label for="search">Search</label>
                <input type="text" id="search" name="search" class="form-control"
                       placeholder="Member name, tier…" value="@search" />
            </div>
            <div class="form-group">
                <label for="state">State</label>
                <select id="state" name="state" class="form-control">
                    <option value="">All</option>
                    <option value="0" selected="@(state == 0)">Pending</option>
                    <option value="1" selected="@(state == 1)">Active</option>
                    <option value="2" selected="@(state == 2)">Queued</option>
                    <option value="3" selected="@(state == 3)">Expired</option>
                </select>
            </div>
            <div class="form-group">
                <label for="tierName">Tier</label>
                <select id="tierName" name="tierName" class="form-control">
                    <option value="">All Tiers</option>
                    @foreach (var tier in tiers)
                    {
                        <option value="@tier.TierName" selected="@(tierName == tier.TierName)">@tier.TierName</option>
                    }
                </select>
            </div>
        </div>
        <div class="search-bar-row">
            <div class="form-group">
                <label for="startFrom">Start From</label>
                <input type="date" id="startFrom" name="startFrom" class="form-control"
                       value="@startFrom?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group">
                <label for="startTo">Start To</label>
                <input type="date" id="startTo" name="startTo" class="form-control"
                       value="@startTo?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group">
                <label for="sortBy">Sort By</label>
                <select id="sortBy" name="sortBy" class="form-control">
                    <option value="">Start Date</option>
                    <option value="memberName" selected="@(sortBy == "memberName")">Member</option>
                    <option value="tierName" selected="@(sortBy == "tierName")">Tier</option>
                    <option value="state" selected="@(sortBy == "state")">State</option>
                    <option value="endDate" selected="@(sortBy == "endDate")">End Date</option>
                </select>
            </div>
            <div class="form-group">
                <label for="sortDir">Direction</label>
                <select id="sortDir" name="sortDir" class="form-control">
                    <option value="asc" selected="@(sortDir == "asc")">Ascending</option>
                    <option value="desc" selected="@(sortDir == "desc")">Descending</option>
                </select>
            </div>
            <div class="form-group search-bar-actions">
                <label>&nbsp;</label>
                <div class="table-actions">
                    <button type="submit" class="btn btn-primary">🔍 Search</button>
                    <a asp-action="Index" class="btn btn-secondary">✕ Clear</a>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="dashboard-card">
    <div class="card-header">
        <h5>Subscription Records</h5>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Member</th>
                <th>Tier</th>
                <th>State</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sub in Model.Items)
            {
                <tr>
                    <td>@sub.SubId</td>
                    <td>@sub.MemberName</td>
                    <td>@sub.TierName</td>
                    <td>
                        <span class="badge @GetStateBadgeClass(sub.State)">@sub.State</span>
                    </td>
                    <td>@(sub.StartDate == default ? "—" : sub.StartDate.ToString("MMM dd, yyyy"))</td>
                    <td>@(sub.EndDate == default ? "—" : sub.EndDate.ToString("MMM dd, yyyy"))</td>
                    <td>
                        <div class="table-actions">
                            <a asp-action="Details" asp-route-id="@sub.SubId" class="btn btn-secondary btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@sub.SubId" class="btn btn-secondary btn-sm">Edit</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <form asp-action="Delete" asp-route-id="@sub.SubId" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this subscription?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <p>No subscriptions found.</p>
        </div>
    }
    <div class="pagination-wrapper">
        <partial name="_Pagination" model="Model" />
    </div>
</div>

@functions {
    string GetStateBadgeClass(SubscriptionState state) => state switch
    {
        SubscriptionState.Active => "badge-active",
        SubscriptionState.Queued => "badge-role",
        SubscriptionState.Pending => "badge-inactive",
        SubscriptionState.Expired => "badge-inactive",
        _ => "badge-inactive"
    };
}