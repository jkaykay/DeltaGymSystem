@model CreateStaffViewModel

@{
    ViewData["Title"] = "Create Staff";
}

<div class="page-header">
    <h1 class="page-header-title">➕ Create New Staff</h1>
    <a asp-action="Index" class="btn btn-secondary">← Back to List</a>
</div>

<div class="form-card">
    <div class="card-header">
        <h5>Staff Information</h5>
    </div>
    <form asp-action="Create" method="post">
        <div class="form-body">
            <div asp-validation-summary="ModelOnly" role="alert"></div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" type="email" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="FirstName"></label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="LastName"></label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="EmployeeId"></label>
                <input asp-for="EmployeeId" class="form-control" placeholder="e.g., GYM-2026-001" />
                <span asp-validation-for="EmployeeId" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="PhoneNumber"></label>
                <input asp-for="PhoneNumber" class="form-control" type="tel" placeholder="e.g. +44 7911 123456" />
                <span asp-validation-for="PhoneNumber" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Role"></label>
                <select asp-for="Role" class="form-control">
                    <option value="Staff">Staff</option>
                    <option value="Admin">Admin</option>
                </select>
                <span asp-validation-for="Role" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="BranchId"></label>
                <select asp-for="BranchId" class="form-control">
                    <option value="">Select branch</option>
                    @foreach (var branch in ViewBag.Branches)
                    {
                        <option value="@branch.BranchId">@branch.City — @branch.Address</option>
                    }
                </select>
                <span asp-validation-for="BranchId" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" type="password" />
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Create Staff</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
