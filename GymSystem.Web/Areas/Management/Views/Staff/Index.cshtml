@model PagedResult<UserDTO>

@{
    ViewData["Title"] = "Manage Staff";
}

<div class="page-header">
    <h1 class="page-header-title">👔 Staff</h1>
    <div class="page-actions">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">➕ Add Staff</a>
        }
        <span class="record-count">@Model.TotalCount total</span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error" role="alert">
        @TempData["Error"]
    </div>
}

<div class="dashboard-card">
    <div class="card-header">
        <h5>Staff &amp; Administrators</h5>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Employee ID</th>
                <th>Hire Date</th>
                <th>Role</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var staff in Model.Items)
            {
                <tr>
                    <td>@staff.FirstName @staff.LastName</td>
                    <td>@staff.Email</td>
                    <td>@(staff.EmployeeId ?? "—")</td>
                    <td>@(staff.HireDate?.ToString("MMM dd, yyyy") ?? "—")</td>
                    <td>
                        @foreach (var role in staff.Roles)
                        {
                            <span class="badge badge-role">@role</span>
                        }
                        @if (!staff.Roles.Any())
                        {
                            <span class="badge badge-inactive">—</span>
                        }
                    </td>
                    <td>
                        @if (staff.Active)
                        {
                            <span class="badge badge-active">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-inactive">Inactive</span>
                        }
                    </td>
                    <td>
                        <div class="table-actions">
                            <a asp-action="Details" asp-route-id="@staff.Id" class="btn btn-secondary btn-sm">Details</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@staff.Id" class="btn btn-secondary btn-sm">Edit</a>
                                <form asp-action="Delete" asp-route-id="@staff.Id" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this staff member?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <p>No staff members found.</p>
        </div>
    }
    <div class="pagination-wrapper">
        <partial name="_Pagination" model="Model" />
    </div>
</div>