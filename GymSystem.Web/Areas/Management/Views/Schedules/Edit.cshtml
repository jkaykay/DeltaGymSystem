@model EditScheduleViewModel

@{
    ViewData["Title"] = "Edit Schedule";
}

<div class="page-header">
    <h1 class="page-header-title">Edit Schedule</h1>
    <a asp-action="Index" class="btn btn-secondary">← Back to List</a>
</div>

<div class="form-card">
    <div class="card-header">
        <h5>Schedule #@Model.ScheduleId — @Model.UserName</h5>
    </div>
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="ScheduleId" />
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="UserName" />
        <div class="form-body">
            <div asp-validation-summary="ModelOnly" role="alert"></div>

            <div class="form-group">
                <label>Employee</label>
                <input type="text" class="form-control" value="@Model.UserName" disabled />
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Start"></label>
                    <input asp-for="Start" class="form-control" type="datetime-local" />
                    <span asp-validation-for="Start" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="End"></label>
                    <input asp-for="End" class="form-control" type="datetime-local" />
                    <span asp-validation-for="End" class="field-validation-error"></span>
                </div>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
