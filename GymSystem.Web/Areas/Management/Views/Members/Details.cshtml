@model MemberResponse

@{
    ViewData["Title"] = "Member Details";
}

<div>
    <h1>Member Details</h1>

    <div style="max-width: 600px;">
        <div>
            <h5>@Model.FirstName @Model.LastName</h5>
        </div>
        <div>
            <dl>
                <dt>Email</dt>
                <dd>@Model.Email</dd>

                <dt>Username</dt>
                <dd>@Model.UserName</dd>

                <dt>Join Date</dt>
                <dd>@Model.JoinDate.ToString("MMMM dd, yyyy")</dd>

                <dt>Status</dt>
                <dd>
                    @if (Model.Active)
                    {
                        <span>Active</span>
                    }
                    else
                    {
                        <span>Inactive</span>
                    }
                </dd>
            </dl>
        </div>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
            <a asp-action="Index">Back to List</a>
        </div>
    </div>
</div>