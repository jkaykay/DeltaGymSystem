@model PagedResult<UserDTO>

@{
    ViewData["Title"] = "Manage Members";

    var search = ViewData["Search"] as string;
    var active = ViewData["Active"] as bool?;
    var joinedFrom = ViewData["JoinedFrom"] as DateTime?;
    var joinedTo = ViewData["JoinedTo"] as DateTime?;
    var sortBy = ViewData["SortBy"] as string;
    var sortDir = ViewData["SortDir"] as string;
}

<div class="page-header">
    <h1 class="page-header-title">👥 Members</h1>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">➕ Add Member</a>
        <span class="record-count">@Model.TotalCount total</span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Success"]
    </div>
}

<div class="dashboard-card" style="margin-bottom: 16px;">
    <div class="card-header">
        <h5>Search &amp; Filter</h5>
    </div>
    <form method="get" asp-action="Index" class="search-bar">
        <div class="search-bar-row">
            <div class="form-group">
                <label for="search">Search</label>
                <input type="text" id="search" name="search" class="form-control"
                       placeholder="Name, email, username…" value="@search" />
            </div>
            <div class="form-group">
                <label for="active">Status</label>
                <select id="active" name="active" class="form-control">
                    <option value="">All</option>
                    <option value="true" selected="@(active == true)">Active</option>
                    <option value="false" selected="@(active == false)">Inactive</option>
                </select>
            </div>
            <div class="form-group">
                <label for="joinedFrom">Joined From</label>
                <input type="date" id="joinedFrom" name="joinedFrom" class="form-control"
                       value="@joinedFrom?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group">
                <label for="joinedTo">Joined To</label>
                <input type="date" id="joinedTo" name="joinedTo" class="form-control"
                       value="@joinedTo?.ToString("yyyy-MM-dd")" />
            </div>
        </div>
        <div class="search-bar-row">
            <div class="form-group">
                <label for="sortBy">Sort By</label>
                <select id="sortBy" name="sortBy" class="form-control">
                    <option value="">Join Date</option>
                    <option value="firstName" selected="@(sortBy == "firstName")">First Name</option>
                    <option value="lastName" selected="@(sortBy == "lastName")">Last Name</option>
                    <option value="email" selected="@(sortBy == "email")">Email</option>
                </select>
            </div>
            <div class="form-group">
                <label for="sortDir">Direction</label>
                <select id="sortDir" name="sortDir" class="form-control">
                    <option value="asc" selected="@(sortDir == "asc")">Ascending</option>
                    <option value="desc" selected="@(sortDir == "desc")">Descending</option>
                </select>
            </div>
            <div class="form-group search-bar-actions">
                <label>&nbsp;</label>
                <div class="table-actions">
                    <button type="submit" class="btn btn-primary">🔍 Search</button>
                    <a asp-action="Index" class="btn btn-secondary">✕ Clear</a>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="dashboard-card">
    <div class="card-header">
        <h5>Member Directory</h5>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Join Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var member in Model.Items)
            {
                <tr>
                    <td>@member.FirstName @member.LastName</td>
                    <td>@member.Email</td>
                    <td>@(member.PhoneNumber ?? "—")</td>
                    <td>@member.JoinDate?.ToString("MMM dd, yyyy")</td>
                    <td>
                        @if (member.Active)
                        {
                            <span class="badge badge-active">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-inactive">Inactive</span>
                        }
                    </td>
                    <td>
                        <div class="table-actions">
                            <a asp-action="Details" asp-route-id="@member.Id" class="btn btn-secondary btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@member.Id" class="btn btn-secondary btn-sm">Edit</a>
                            <form asp-action="ToggleActive" asp-route-id="@member.Id" method="post">
                                <button type="submit" class="btn btn-sm @(member.Active ? "btn-warning" : "btn-success")">
                                    @(member.Active ? "Deactivate" : "Activate")
                                </button>
                            </form>
                            @if (User.IsInRole("Admin"))
                            {
                                <form asp-action="Delete" asp-route-id="@member.Id" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this member?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <p>No members found.</p>
        </div>
    }
    <div class="pagination-wrapper">
        <partial name="_Pagination" model="Model" />
    </div>
</div>