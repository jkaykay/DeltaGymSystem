@model List<UserDTO>

@{
    ViewData["Title"] = "Manage Members";
}

<div>
    <div>
        <h1>👥 Members</h1>
        <div>
            <a asp-action="Create">➕ Add Member</a>
            <span>@Model.Count total</span>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div role="alert">
            @TempData["Success"]
            <button type="button" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div>
        <div>
            <h5>Member List</h5>
        </div>
        <div>
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Join Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var member in Model)
                    {
                        <tr>
                            <td>@member.FirstName @member.LastName</td>
                            <td>@member.Email</td>
                            <td>@member.JoinDate?.ToString("MMM dd, yyyy")</td>
                            <td>
                                @if (member.Active)
                                {
                                    <span>Active</span>
                                }
                                else
                                {
                                    <span>Inactive</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@member.Id">
                                    Details
                                </a>
                                <a asp-action="Edit" asp-route-id="@member.Id">
                                    Edit
                                </a>
                                <form asp-action="ToggleActive" asp-route-id="@member.Id" method="post">
                                    <button type="submit">
                                        @(member.Active ? "Deactivate" : "Activate")
                                    </button>
                                </form>
                                @if (User.IsInRole("Admin"))
                                {
                                    <form asp-action="Delete" asp-route-id="@member.Id" method="post"
                                          onsubmit="return confirm('Are you sure you want to delete this member?');">
                                        <button type="submit">Delete</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div>
                <p>No members found.</p>
            </div>
        }
    </div>
</div>