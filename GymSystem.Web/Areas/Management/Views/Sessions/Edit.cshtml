@model EditSessionViewModel
@using GymSystem.Shared.DTOs

@{
    ViewData["Title"] = "Edit Session";
    var rooms = ViewBag.Rooms as List<RoomDTO> ?? new List<RoomDTO>();
}

<div class="page-header">
    <h1 class="page-header-title">Edit Session</h1>
    <a asp-action="Index" class="btn btn-secondary">← Back to List</a>
</div>

<div class="form-card">
    <div class="card-header">
        <h5>@Model.Subject</h5>
    </div>
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="SessionId" />
        <input type="hidden" asp-for="ClassId" />
        <input type="hidden" asp-for="Subject" />
        <div class="form-body">
            <div asp-validation-summary="ModelOnly" role="alert"></div>

            <div class="form-group">
                <label>Class</label>
                <input value="@Model.Subject" class="form-control" disabled />
                <small class="form-text">Class cannot be changed after creation.</small>
            </div>

            <div class="form-group">
                <label asp-for="RoomId"></label>
                <select asp-for="RoomId" class="form-control">
                    <option value="">— Select a Room —</option>
                    @foreach (var room in rooms)
                    {
                        <option value="@room.RoomId" selected="@(Model.RoomId == room.RoomId)">
                            Room @room.RoomNumber (Capacity: @room.MaxCapacity)
                        </option>
                    }
                </select>
                <span asp-validation-for="RoomId" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Start"></label>
                    <input asp-for="Start" class="form-control" type="datetime-local"
                           value="@Model.Start.ToString("yyyy-MM-ddTHH:mm")" />
                    <span asp-validation-for="Start" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="End"></label>
                    <input asp-for="End" class="form-control" type="datetime-local"
                           value="@Model.End.ToString("yyyy-MM-ddTHH:mm")" />
                    <span asp-validation-for="End" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="MaxCapacity"></label>
                <input asp-for="MaxCapacity" class="form-control" type="number" min="1" max="100" />
                <span asp-validation-for="MaxCapacity" class="field-validation-error"></span>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}