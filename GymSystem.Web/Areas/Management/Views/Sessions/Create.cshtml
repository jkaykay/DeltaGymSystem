@model CreateSessionViewModel
@using GymSystem.Shared.DTOs

@{
    ViewData["Title"] = "Create Session";
    var classes = ViewBag.Classes as List<ClassDTO> ?? new List<ClassDTO>();
    var rooms = ViewBag.Rooms as List<RoomDTO> ?? new List<RoomDTO>();
}

<div class="page-header">
    <h1 class="page-header-title">➕ Create New Session</h1>
    <a asp-action="Index" class="btn btn-secondary">← Back to List</a>
</div>

<div class="form-card">
    <div class="card-header">
        <h5>Session Information</h5>
    </div>
    <form asp-action="Create" method="post">
        <div class="form-body">
            <div asp-validation-summary="ModelOnly" role="alert"></div>

            <div class="form-group">
                <label asp-for="ClassId"></label>
                <select asp-for="ClassId" class="form-control">
                    <option value="">— Select a Class —</option>
                    @foreach (var gymClass in classes)
                    {
                        <option value="@gymClass.ClassId">@gymClass.Subject (@gymClass.TrainerName)</option>
                    }
                </select>
                <span asp-validation-for="ClassId" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="RoomId"></label>
                <select asp-for="RoomId" class="form-control">
                    <option value="">— Select a Room —</option>
                    @foreach (var room in rooms)
                    {
                        <option value="@room.RoomId">Room @room.RoomNumber (Capacity: @room.MaxCapacity)</option>
                    }
                </select>
                <span asp-validation-for="RoomId" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Start"></label>
                    <input asp-for="Start" class="form-control" type="datetime-local" />
                    <span asp-validation-for="Start" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="End"></label>
                    <input asp-for="End" class="form-control" type="datetime-local" />
                    <span asp-validation-for="End" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="MaxCapacity"></label>
                <input asp-for="MaxCapacity" class="form-control" type="number" min="1" max="100" />
                <span asp-validation-for="MaxCapacity" class="field-validation-error"></span>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Create Session</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}