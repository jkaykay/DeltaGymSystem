@model PagedResult<SessionDTO>

@{
    ViewData["Title"] = "Manage Sessions";

    var search = ViewData["Search"] as string;
    var dateFrom = ViewData["DateFrom"] as DateTime?;
    var dateTo = ViewData["DateTo"] as DateTime?;
    var roomId = ViewData["RoomId"] as int?;
    var sortBy = ViewData["SortBy"] as string;
    var sortDir = ViewData["SortDir"] as string;

    var rooms = ViewBag.Rooms as List<RoomDTO> ?? new List<RoomDTO>();
}

<div class="page-header">
    <h1 class="page-header-title">🗓️ Sessions</h1>
    <div class="page-actions">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">➕ Add Session</a>
        }
        <span class="record-count">@Model.TotalCount total</span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error" role="alert">
        @TempData["Error"]
    </div>
}

<div class="dashboard-card" style="margin-bottom: 16px;">
    <div class="card-header">
        <h5>Search &amp; Filter</h5>
    </div>
    <form method="get" asp-action="Index" class="search-bar">
        <div class="search-bar-row">
            <div class="form-group">
                <label for="search">Search</label>
                <input type="text" id="search" name="search" class="form-control"
                       placeholder="Subject, instructor…" value="@search" />
            </div>
            <div class="form-group">
                <label for="roomId">Room</label>
                <select id="roomId" name="roomId" class="form-control">
                    <option value="">All Rooms</option>
                    @foreach (var room in rooms)
                    {
                        <option value="@room.RoomId" selected="@(roomId == room.RoomId)">Room @room.RoomNumber</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label for="dateFrom">From</label>
                <input type="date" id="dateFrom" name="dateFrom" class="form-control"
                       value="@dateFrom?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group">
                <label for="dateTo">To</label>
                <input type="date" id="dateTo" name="dateTo" class="form-control"
                       value="@dateTo?.ToString("yyyy-MM-dd")" />
            </div>
        </div>
        <div class="search-bar-row">
            <div class="form-group">
                <label for="sortBy">Sort By</label>
                <select id="sortBy" name="sortBy" class="form-control">
                    <option value="">Start Time</option>
                    <option value="subject" selected="@(sortBy == "subject")">Subject</option>
                    <option value="instructor" selected="@(sortBy == "instructor")">Instructor</option>
                    <option value="room" selected="@(sortBy == "room")">Room</option>
                    <option value="capacity" selected="@(sortBy == "capacity")">Capacity</option>
                </select>
            </div>
            <div class="form-group">
                <label for="sortDir">Direction</label>
                <select id="sortDir" name="sortDir" class="form-control">
                    <option value="asc" selected="@(sortDir == "asc")">Ascending</option>
                    <option value="desc" selected="@(sortDir == "desc")">Descending</option>
                </select>
            </div>
            <div class="form-group search-bar-actions">
                <label>&nbsp;</label>
                <div class="table-actions">
                    <button type="submit" class="btn btn-primary">🔍 Search</button>
                    <a asp-action="Index" class="btn btn-secondary">✕ Clear</a>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="dashboard-card">
    <div class="card-header">
        <h5>Scheduled Sessions</h5>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Subject</th>
                <th>Instructor</th>
                <th>Room</th>
                <th>Start</th>
                <th>End</th>
                <th>Capacity</th>
                <th>Bookings</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var session in Model.Items)
            {
                <tr>
                    <td>@session.Subject</td>
                    <td>@session.InstructorName</td>
                    <td>Room @session.RoomNumber</td>
                    <td>@session.Start.ToString("MMM dd, yyyy HH:mm")</td>
                    <td>@session.End.ToString("MMM dd, yyyy HH:mm")</td>
                    <td>@session.MaxCapacity</td>
                    <td>@session.BookingCount / @session.MaxCapacity</td>
                    <td>
                        <div class="table-actions">
                            <a asp-action="Details" asp-route-id="@session.SessionId" class="btn btn-secondary btn-sm">Details</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@session.SessionId" class="btn btn-secondary btn-sm">Edit</a>
                                <form asp-action="Delete" asp-route-id="@session.SessionId" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this session?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <p>No sessions found.</p>
        </div>
    }
    <div class="pagination-wrapper">
        <partial name="_Pagination" model="Model" />
    </div>
</div>