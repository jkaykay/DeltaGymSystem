@model PagedResult<EquipmentDTO>

@{
    ViewData["Title"] = "Manage Equipment";
}

<div class="page-header">
    <h1 class="page-header-title">🏋️ Equipment</h1>
    <div class="page-actions">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">➕ Add Equipment</a>
        }
        <span class="record-count">@Model.TotalCount total</span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error" role="alert">
        @TempData["Error"]
    </div>
}

<div class="dashboard-card">
    <div class="card-header">
        <h5>Equipment Directory</h5>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Description</th>
                <th>Date Acquired</th>
                <th>Status</th>
                <th>Room</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.EquipmentId</td>
                    <td>@(item.Description ?? "—")</td>
                    <td>@item.InDate.ToString("MMM dd, yyyy")</td>
                    <td>@(item.Operational ? "✅ Operational" : "❌ Out of Service")</td>
                    <td>Room @item.RoomNumber</td>
                    <td>
                        <div class="table-actions">
                            <a asp-action="Details" asp-route-id="@item.EquipmentId" class="btn btn-secondary btn-sm">Details</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.EquipmentId" class="btn btn-secondary btn-sm">Edit</a>
                                <form asp-action="Delete" asp-route-id="@item.EquipmentId" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this equipment?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <p>No equipment found.</p>
        </div>
    }
    <div class="pagination-wrapper">
        <partial name="_Pagination" model="Model" />
    </div>
</div>
