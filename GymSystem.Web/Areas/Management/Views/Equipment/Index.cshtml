@model PagedResult<EquipmentDTO>

@{
    ViewData["Title"] = "Manage Equipment";

    var search = ViewData["Search"] as string;
    var operational = ViewData["Operational"] as bool?;
    var roomId = ViewData["RoomId"] as int?;
    var dateFrom = ViewData["DateFrom"] as DateTime?;
    var dateTo = ViewData["DateTo"] as DateTime?;
    var sortBy = ViewData["SortBy"] as string;
    var sortDir = ViewData["SortDir"] as string;

    var rooms = ViewBag.Rooms as List<RoomDTO> ?? new List<RoomDTO>();
}

<div class="page-header">
    <h1 class="page-header-title">🏋️ Equipment</h1>
    <div class="page-actions">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">➕ Add Equipment</a>
        }
        <span class="record-count">@Model.TotalCount total</span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error" role="alert">
        @TempData["Error"]
    </div>
}

<div class="dashboard-card" style="margin-bottom: 16px;">
    <div class="card-header">
        <h5>Search &amp; Filter</h5>
    </div>
    <form method="get" asp-action="Index" class="search-bar">
        <div class="search-bar-row">
            <div class="form-group">
                <label for="search">Search</label>
                <input type="text" id="search" name="search" class="form-control"
                       placeholder="Description…" value="@search" />
            </div>
            <div class="form-group">
                <label for="operational">Status</label>
                <select id="operational" name="operational" class="form-control">
                    <option value="">All</option>
                    <option value="true" selected="@(operational == true)">Operational</option>
                    <option value="false" selected="@(operational == false)">Out of Service</option>
                </select>
            </div>
            <div class="form-group">
                <label for="roomId">Room</label>
                <select id="roomId" name="roomId" class="form-control">
                    <option value="">All Rooms</option>
                    @foreach (var room in rooms)
                    {
                        <option value="@room.RoomId" selected="@(roomId == room.RoomId)">Room @room.RoomNumber</option>
                    }
                </select>
            </div>
        </div>
        <div class="search-bar-row">
            <div class="form-group">
                <label for="dateFrom">Acquired From</label>
                <input type="date" id="dateFrom" name="dateFrom" class="form-control"
                       value="@dateFrom?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group">
                <label for="dateTo">Acquired To</label>
                <input type="date" id="dateTo" name="dateTo" class="form-control"
                       value="@dateTo?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group">
                <label for="sortBy">Sort By</label>
                <select id="sortBy" name="sortBy" class="form-control">
                    <option value="">Date Acquired</option>
                    <option value="description" selected="@(sortBy == "description")">Description</option>
                    <option value="status" selected="@(sortBy == "status")">Status</option>
                    <option value="room" selected="@(sortBy == "room")">Room</option>
                </select>
            </div>
            <div class="form-group">
                <label for="sortDir">Direction</label>
                <select id="sortDir" name="sortDir" class="form-control">
                    <option value="asc" selected="@(sortDir == "asc")">Ascending</option>
                    <option value="desc" selected="@(sortDir == "desc")">Descending</option>
                </select>
            </div>
            <div class="form-group search-bar-actions">
                <label>&nbsp;</label>
                <div class="table-actions">
                    <button type="submit" class="btn btn-primary">🔍 Search</button>
                    <a asp-action="Index" class="btn btn-secondary">✕ Clear</a>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="dashboard-card">
    <div class="card-header">
        <h5>Equipment Directory</h5>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Description</th>
                <th>Date Acquired</th>
                <th>Status</th>
                <th>Room</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.EquipmentId</td>
                    <td>@(item.Description ?? "—")</td>
                    <td>@item.InDate.ToString("MMM dd, yyyy")</td>
                    <td>@(item.Operational ? "✅ Operational" : "❌ Out of Service")</td>
                    <td>Room @item.RoomNumber</td>
                    <td>
                        <div class="table-actions">
                            <a asp-action="Details" asp-route-id="@item.EquipmentId" class="btn btn-secondary btn-sm">Details</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.EquipmentId" class="btn btn-secondary btn-sm">Edit</a>
                                <form asp-action="Delete" asp-route-id="@item.EquipmentId" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this equipment?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <p>No equipment found.</p>
        </div>
    }
    <div class="pagination-wrapper">
        <partial name="_Pagination" model="Model" />
    </div>
</div>
