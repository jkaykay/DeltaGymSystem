@model CreateEquipmentViewModel
@using GymSystem.Shared.DTOs

@{
    ViewData["Title"] = "Add Equipment";
    var rooms = ViewBag.Rooms as List<RoomDTO> ?? new List<RoomDTO>();
}

<div class="page-header">
    <h1 class="page-header-title">➕ Add New Equipment</h1>
    <a asp-action="Index" class="btn btn-secondary">← Back to List</a>
</div>

<div class="form-card">
    <div class="card-header">
        <h5>Equipment Information</h5>
    </div>
    <form asp-action="Create" method="post">
        <div class="form-body">
            <div asp-validation-summary="ModelOnly" role="alert"></div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="RoomId"></label>
                <select asp-for="RoomId" class="form-control">
                    <option value="">— Select a Room —</option>
                    @foreach (var room in rooms)
                    {
                        <option value="@room.RoomId">Room @room.RoomNumber — Branch @room.BranchId</option>
                    }
                </select>
                <span asp-validation-for="RoomId" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="InDate"></label>
                    <input asp-for="InDate" class="form-control" type="date" />
                    <span asp-validation-for="InDate" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Operational"></label>
                    <input asp-for="Operational" class="form-control" type="checkbox" />
                    <span asp-validation-for="Operational" class="field-validation-error"></span>
                </div>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Add Equipment</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
