@model CreateTierViewModel

@{
    ViewData["Title"] = "Create Tier";
}

<div class="page-header">
    <h1 class="page-header-title">➕ Create New Tier</h1>
    <a asp-action="Index" class="btn btn-secondary">← Back to List</a>
</div>

<div class="form-card">
    <div class="card-header">
        <h5>Tier Information</h5>
    </div>
    <form asp-action="Create" method="post">
        <div class="form-body">
            <div asp-validation-summary="ModelOnly" role="alert"></div>

            <div class="form-group">
                <label asp-for="TierName"></label>
                <input asp-for="TierName" class="form-control" placeholder="e.g. Gold, Silver, Basic" />
                <span asp-validation-for="TierName" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Price"></label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0.01" />
                <span asp-validation-for="Price" class="field-validation-error"></span>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Create Tier</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}