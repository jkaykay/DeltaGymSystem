@model EditTierViewModel

@{
    ViewData["Title"] = "Edit Tier";
}

<div class="page-header">
    <h1 class="page-header-title">Edit Tier</h1>
    <a asp-action="Index" class="btn btn-secondary">← Back to List</a>
</div>

<div class="form-card">
    <div class="card-header">
        <h5>@Model.TierName</h5>
    </div>
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="TierName" />
        <div class="form-body">
            <div asp-validation-summary="ModelOnly" role="alert"></div>

            <div class="form-group">
                <label asp-for="TierName"></label>
                <input value="@Model.TierName" class="form-control" disabled />
                <small class="form-text">Tier name cannot be changed after creation.</small>
            </div>

            <div class="form-group">
                <label asp-for="Price"></label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0.01" />
                <span asp-validation-for="Price" class="field-validation-error"></span>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}