@model PagedResult<TierDTO>

@{
    ViewData["Title"] = "Manage Tiers";
}

<div class="page-header">
    <h1 class="page-header-title">💳 Membership Tiers</h1>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">➕ Add Tier</a>
        <span class="record-count">@Model.TotalCount total</span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error" role="alert">
        @TempData["Error"]
    </div>
}

<div class="dashboard-card">
    <div class="card-header">
        <h5>Pricing Tiers</h5>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Tier Name</th>
                <th>Monthly Price</th>
                <th>Active Subscriptions</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tier in Model.Items)
            {
                <tr>
                    <td>@tier.TierName</td>
                    <td>@tier.Price.ToString("C")</td>
                    <td>@tier.SubCount</td>
                    <td>
                        <div class="table-actions">
                            <a asp-action="Details" asp-route-id="@tier.TierName" class="btn btn-secondary btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@tier.TierName" class="btn btn-secondary btn-sm">Edit</a>
                            <form asp-action="Delete" asp-route-id="@tier.TierName" method="post"
                                  onsubmit="return confirm('Are you sure you want to delete the @tier.TierName tier?');">
                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <p>No tiers found.</p>
        </div>
    }
    <div class="pagination-wrapper">
        <partial name="_Pagination" model="Model" />
    </div>
</div>