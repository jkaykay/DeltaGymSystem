@model PagedResult<TierDTO>

@{
    ViewData["Title"] = "Manage Tiers";

    var search = ViewData["Search"] as string;
    var sortBy = ViewData["SortBy"] as string;
    var sortDir = ViewData["SortDir"] as string;
}

<div class="page-header">
    <h1 class="page-header-title">💳 Membership Tiers</h1>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">➕ Add Tier</a>
        <span class="record-count">@Model.TotalCount total</span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error" role="alert">
        @TempData["Error"]
    </div>
}

<div class="dashboard-card" style="margin-bottom: 16px;">
    <div class="card-header">
        <h5>Search &amp; Filter</h5>
    </div>
    <form method="get" asp-action="Index" class="search-bar">
        <div class="search-bar-row">
            <div class="form-group">
                <label for="search">Search</label>
                <input type="text" id="search" name="search" class="form-control"
                       placeholder="Tier name…" value="@search" />
            </div>
            <div class="form-group">
                <label for="sortBy">Sort By</label>
                <select id="sortBy" name="sortBy" class="form-control">
                    <option value="">Name</option>
                    <option value="price" selected="@(sortBy == "price")">Price</option>
                    <option value="subscriptions" selected="@(sortBy == "subscriptions")">Subscriptions</option>
                </select>
            </div>
            <div class="form-group">
                <label for="sortDir">Direction</label>
                <select id="sortDir" name="sortDir" class="form-control">
                    <option value="asc" selected="@(sortDir == "asc")">Ascending</option>
                    <option value="desc" selected="@(sortDir == "desc")">Descending</option>
                </select>
            </div>
            <div class="form-group search-bar-actions">
                <label>&nbsp;</label>
                <div class="table-actions">
                    <button type="submit" class="btn btn-primary">🔍 Search</button>
                    <a asp-action="Index" class="btn btn-secondary">✕ Clear</a>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="dashboard-card">
    <div class="card-header">
        <h5>Pricing Tiers</h5>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Tier Name</th>
                <th>Monthly Price</th>
                <th>Active Subscriptions</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tier in Model.Items)
            {
                <tr>
                    <td>@tier.TierName</td>
                    <td>@tier.Price.ToString("C")</td>
                    <td>@tier.SubCount</td>
                    <td>
                        <div class="table-actions">
                            <a asp-action="Details" asp-route-id="@tier.TierName" class="btn btn-secondary btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@tier.TierName" class="btn btn-secondary btn-sm">Edit</a>
                            <form asp-action="Delete" asp-route-id="@tier.TierName" method="post"
                                  onsubmit="return confirm('Are you sure you want to delete the @tier.TierName tier?');">
                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <p>No tiers found.</p>
        </div>
    }
    <div class="pagination-wrapper">
        <partial name="_Pagination" model="Model" />
    </div>
</div>