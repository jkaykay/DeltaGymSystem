@model PagedResult<ClassDTO>

@{
    ViewData["Title"] = "Manage Classes";
}

<div class="page-header">
    <h1 class="page-header-title">📋 Classes</h1>
    <div class="page-actions">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">➕ Add Class</a>
        }
        <span class="record-count">@Model.TotalCount total</span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error" role="alert">
        @TempData["Error"]
    </div>
}

<div class="dashboard-card">
    <div class="card-header">
        <h5>Class Directory</h5>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Subject</th>
                <th>Trainer</th>
                <th>Sessions</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var gymClass in Model.Items)
            {
                <tr>
                    <td>@gymClass.ClassId</td>
                    <td>@gymClass.Subject</td>
                    <td>@gymClass.TrainerName</td>
                    <td>@gymClass.SessionCount</td>
                    <td>
                        <div class="table-actions">
                            <a asp-action="Details" asp-route-id="@gymClass.ClassId" class="btn btn-secondary btn-sm">Details</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@gymClass.ClassId" class="btn btn-secondary btn-sm">Edit</a>
                                <form asp-action="Delete" asp-route-id="@gymClass.ClassId" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this class?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <p>No classes found.</p>
        </div>
    }
    <div class="pagination-wrapper">
        <partial name="_Pagination" model="Model" />
    </div>
</div>