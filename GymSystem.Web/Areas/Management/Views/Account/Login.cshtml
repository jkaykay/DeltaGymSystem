@model ManagementLoginViewModel

@{
    ViewData["Title"] = "Management Login";
    Layout = "~/Areas/Management/Views/Shared/_ManagementLoginLayout.cshtml";
}

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-header">
            <h3 class="login-title">⚙️ Management Portal</h3>
        </div>
        <div class="login-body-content">
            <h5 class="login-subtitle">Sign in to continue</h5>

            <form method="post" asp-action="Login" asp-area="Management">
                <div asp-validation-summary="ModelOnly" class="login-error" role="alert"></div>

                <div class="login-field">
                    <label asp-for="Email" class="login-label">Email Address</label>
                    <input asp-for="Email" type="email" class="login-input" required />
                    <span asp-validation-for="Email" class="login-validation"></span>
                </div>

                <div class="login-field">
                    <label asp-for="Password" class="login-label">Password</label>
                    <input asp-for="Password" type="password" class="login-input" required />
                    <span asp-validation-for="Password" class="login-validation"></span>
                </div>

                <div class="login-remember">
                    <input asp-for="RememberMe" id="RememberMe" />
                    <label asp-for="RememberMe">Remember me</label>
                </div>

                <button type="submit" class="btn btn-primary login-btn">Login</button>
            </form>
        </div>
        <div class="login-footer">
            <small>Authorized personnel only</small>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}