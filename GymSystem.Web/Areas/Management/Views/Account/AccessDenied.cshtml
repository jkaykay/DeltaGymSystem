@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Areas/Management/Views/Shared/_ManagementLoginLayout.cshtml";
}

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-header">
            <h3 class="login-title">🚫 Access Denied</h3>
        </div>
        <div class="login-body-content">
            <h5 class="login-subtitle">You do not have permission to access this page.</h5>
            <p style="margin-top: 15px; color: #666;">
                Please contact an administrator if you believe this is an error.
            </p>
            <a asp-action="Login" asp-controller="Account" asp-area="Management"
               class="btn btn-primary login-btn" style="margin-top: 20px; display: inline-block; text-decoration: none;">
                Back to Login
            </a>
        </div>
        <div class="login-footer">
            <small>Authorized personnel only</small>
        </div>
    </div>
</div>
