@model DashboardViewModel

@{
    ViewData["Title"] = "Management Dashboard";
}

<div>
    <h1>Dashboard</h1>

    <!-- Stats Cards -->
    <div>
        <div >
            <div>
                <div>
                    <h5>Total Members</h5>
                    <h2>@Model.TotalMembers</h2>
                </div>
            </div>
        </div>
        <div >
            <div>
                <div>
                    <h5>Staff</h5>
                    <h2>@Model.TotalStaff</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->

    
    <div>
        <div>
            <div>
                <div>
                    <h5>Quick Actions</h5>
                </div>
                <div>
                    <a href="@Url.Action("Index", "Members")">
                        <span>Manage Members</span>
                        <span>View All</span>
                    </a>
                    <a href="@Url.Action("Index", "Staff")">
                        <span>Manage Staff</span>
                        <span>Admin Only</span>
                    </a>
                    <a href="@Url.Action("Index", "Memberships")">
                        Membership Plans
                    </a>
                    <a href="@Url.Action("Index", "Reports")">
                        Reports
                    </a>
                </div>
            </div>
        </div>
        

        <div>
            <div>
                <div>
                    <h5>Recent Signups</h5>
                </div>
                <ul>
                    @foreach (var user in Model.RecentSignups)
                    {
                        <li>
                            <span>@user.FirstName @user.LastName</span>
                            <small>@user.JoinDate.ToString("MMM dd, yyyy")</small>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>