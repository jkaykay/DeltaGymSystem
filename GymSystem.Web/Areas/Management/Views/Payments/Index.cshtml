@model PagedResult<PaymentDTO>

@{
    ViewData["Title"] = "Manage Payments";

    var search = ViewData["Search"] as string;
    var dateFrom = ViewData["DateFrom"] as DateTime?;
    var dateTo = ViewData["DateTo"] as DateTime?;
    var minAmount = ViewData["MinAmount"] as decimal?;
    var maxAmount = ViewData["MaxAmount"] as decimal?;
    var sortBy = ViewData["SortBy"] as string;
    var sortDir = ViewData["SortDir"] as string;
}

<div class="page-header">
    <h1 class="page-header-title">💰 Payments</h1>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">➕ Record Payment</a>
        <span class="record-count">@Model.TotalCount total</span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error" role="alert">
        @TempData["Error"]
    </div>
}

<div class="dashboard-card" style="margin-bottom: 16px;">
    <div class="card-header">
        <h5>Search &amp; Filter</h5>
    </div>
    <form method="get" asp-action="Index" class="search-bar">
        <div class="search-bar-row">
            <div class="form-group">
                <label for="search">Search</label>
                <input type="text" id="search" name="search" class="form-control"
                       placeholder="Member name, email…" value="@search" />
            </div>
            <div class="form-group">
                <label for="dateFrom">Date From</label>
                <input type="date" id="dateFrom" name="dateFrom" class="form-control"
                       value="@dateFrom?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group">
                <label for="dateTo">Date To</label>
                <input type="date" id="dateTo" name="dateTo" class="form-control"
                       value="@dateTo?.ToString("yyyy-MM-dd")" />
            </div>
        </div>
        <div class="search-bar-row">
            <div class="form-group">
                <label for="minAmount">Min Amount</label>
                <input type="number" id="minAmount" name="minAmount" class="form-control"
                       step="0.01" placeholder="0.00" value="@minAmount" />
            </div>
            <div class="form-group">
                <label for="maxAmount">Max Amount</label>
                <input type="number" id="maxAmount" name="maxAmount" class="form-control"
                       step="0.01" placeholder="0.00" value="@maxAmount" />
            </div>
            <div class="form-group">
                <label for="sortBy">Sort By</label>
                <select id="sortBy" name="sortBy" class="form-control">
                    <option value="">Date</option>
                    <option value="amount" selected="@(sortBy == "amount")">Amount</option>
                    <option value="member" selected="@(sortBy == "member")">Member</option>
                    <option value="subId" selected="@(sortBy == "subId")">Subscription</option>
                </select>
            </div>
            <div class="form-group">
                <label for="sortDir">Direction</label>
                <select id="sortDir" name="sortDir" class="form-control">
                    <option value="asc" selected="@(sortDir == "asc")">Ascending</option>
                    <option value="desc" selected="@(sortDir == "desc")">Descending</option>
                </select>
            </div>
            <div class="form-group search-bar-actions">
                <label>&nbsp;</label>
                <div class="table-actions">
                    <button type="submit" class="btn btn-primary">🔍 Search</button>
                    <a asp-action="Index" class="btn btn-secondary">✕ Clear</a>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="dashboard-card">
    <div class="card-header">
        <h5>Payment Records</h5>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Member</th>
                <th>Subscription</th>
                <th>Amount</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var payment in Model.Items)
            {
                <tr>
                    <td>@payment.PaymentId</td>
                    <td>@payment.UserFullName</td>
                    <td>#@payment.SubId</td>
                    <td>@payment.Amount.ToString("C")</td>
                    <td>@payment.PaymentDate.ToString("MMM dd, yyyy HH:mm")</td>
                    <td>
                        <div class="table-actions">
                            <a asp-action="Details" asp-route-id="@payment.PaymentId" class="btn btn-secondary btn-sm">Details</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <form asp-action="Delete" asp-route-id="@payment.PaymentId" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this payment? This action cannot be undone.');">
                                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <p>No payments found.</p>
        </div>
    }
    <div class="pagination-wrapper">
        <partial name="_Pagination" model="Model" />
    </div>
</div>