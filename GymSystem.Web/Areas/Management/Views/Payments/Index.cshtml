@model PagedResult<PaymentDTO>

@{
    ViewData["Title"] = "Manage Payments";
}

<div class="page-header">
    <h1 class="page-header-title">💰 Payments</h1>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">➕ Record Payment</a>
        <span class="record-count">@Model.TotalCount total</span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error" role="alert">
        @TempData["Error"]
    </div>
}

<div class="dashboard-card">
    <div class="card-header">
        <h5>Payment Records</h5>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Member ID</th>
                <th>Subscription</th>
                <th>Amount</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var payment in Model.Items)
            {
                <tr>
                    <td>@payment.PaymentId</td>
                    <td><code>@payment.UserId</code></td>
                    <td>#@payment.SubId</td>
                    <td>@payment.Amount.ToString("C")</td>
                    <td>@payment.PaymentDate.ToString("MMM dd, yyyy HH:mm")</td>
                    <td>
                        <div class="table-actions">
                            <a asp-action="Details" asp-route-id="@payment.PaymentId" class="btn btn-secondary btn-sm">Details</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <form asp-action="Delete" asp-route-id="@payment.PaymentId" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this payment? This action cannot be undone.');">
                                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <p>No payments found.</p>
        </div>
    }
    <div class="pagination-wrapper">
        <partial name="_Pagination" model="Model" />
    </div>
</div>