@model CreateRoomViewModel
@using GymSystem.Shared.DTOs

@{
    ViewData["Title"] = "Create Room";
    var branches = ViewBag.Branches as List<BranchDTO> ?? new List<BranchDTO>();
}

<div class="page-header">
    <h1 class="page-header-title">➕ Create New Room</h1>
    <a asp-action="Index" class="btn btn-secondary">← Back to List</a>
</div>

<div class="form-card">
    <div class="card-header">
        <h5>Room Information</h5>
    </div>
    <form asp-action="Create" method="post">
        <div class="form-body">
            <div asp-validation-summary="ModelOnly" role="alert"></div>

            <div class="form-group">
                <label asp-for="BranchId"></label>
                <select asp-for="BranchId" class="form-control">
                    <option value="">— Select a Branch —</option>
                    @foreach (var branch in branches)
                    {
                        <option value="@branch.BranchId">@branch.City — @branch.Address</option>
                    }
                </select>
                <span asp-validation-for="BranchId" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="RoomNumber"></label>
                    <input asp-for="RoomNumber" class="form-control" type="number" min="1" max="100" />
                    <span asp-validation-for="RoomNumber" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="MaxCapacity"></label>
                    <input asp-for="MaxCapacity" class="form-control" type="number" min="1" max="100" />
                    <span asp-validation-for="MaxCapacity" class="field-validation-error"></span>
                </div>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Create Room</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}