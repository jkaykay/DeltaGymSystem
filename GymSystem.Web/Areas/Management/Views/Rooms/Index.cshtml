@model PagedResult<RoomDTO>

@{
    ViewData["Title"] = "Manage Rooms";

    var branchId = ViewData["BranchId"] as int?;
    var roomNumber = ViewData["RoomNumber"] as int?;
    var sortBy = ViewData["SortBy"] as string;
    var sortDir = ViewData["SortDir"] as string;

    var branches = ViewBag.Branches as List<BranchDTO> ?? new List<BranchDTO>();
}

<div class="page-header">
    <h1 class="page-header-title">🚪 Rooms</h1>
    <div class="page-actions">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">➕ Add Room</a>
        }
        <span class="record-count">@Model.TotalCount total</span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-error" role="alert">
        @TempData["Error"]
    </div>
}

<div class="dashboard-card" style="margin-bottom: 16px;">
    <div class="card-header">
        <h5>Search &amp; Filter</h5>
    </div>
    <form method="get" asp-action="Index" class="search-bar">
        <div class="search-bar-row">
            <div class="form-group">
                <label for="branchId">Branch</label>
                <select id="branchId" name="branchId" class="form-control">
                    <option value="">All Branches</option>
                    @foreach (var branch in branches)
                    {
                        <option value="@branch.BranchId" selected="@(branchId == branch.BranchId)">@branch.City — @branch.Address</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label for="roomNumber">Room #</label>
                <input type="number" id="roomNumber" name="roomNumber" class="form-control"
                       placeholder="Room number" value="@roomNumber" />
            </div>
            <div class="form-group">
                <label for="sortBy">Sort By</label>
                <select id="sortBy" name="sortBy" class="form-control">
                    <option value="">Room Number</option>
                    <option value="branch" selected="@(sortBy == "branch")">Branch</option>
                    <option value="capacity" selected="@(sortBy == "capacity")">Capacity</option>
                    <option value="sessions" selected="@(sortBy == "sessions")">Sessions</option>
                    <option value="equipment" selected="@(sortBy == "equipment")">Equipment</option>
                </select>
            </div>
            <div class="form-group">
                <label for="sortDir">Direction</label>
                <select id="sortDir" name="sortDir" class="form-control">
                    <option value="asc" selected="@(sortDir == "asc")">Ascending</option>
                    <option value="desc" selected="@(sortDir == "desc")">Descending</option>
                </select>
            </div>
            <div class="form-group search-bar-actions">
                <label>&nbsp;</label>
                <div class="table-actions">
                    <button type="submit" class="btn btn-primary">🔍 Search</button>
                    <a asp-action="Index" class="btn btn-secondary">✕ Clear</a>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="dashboard-card">
    <div class="card-header">
        <h5>Room Directory</h5>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>Room #</th>
                <th>Branch ID</th>
                <th>Max Capacity</th>
                <th>Sessions</th>
                <th>Equipment</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var room in Model.Items)
            {
                <tr>
                    <td>@room.RoomNumber</td>
                    <td>@room.BranchId</td>
                    <td>@room.MaxCapacity</td>
                    <td>@room.SessionCount</td>
                    <td>@room.EquipmentCount</td>
                    <td>
                        <div class="table-actions">
                            <a asp-action="Details" asp-route-id="@room.RoomId" class="btn btn-secondary btn-sm">Details</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@room.RoomId" class="btn btn-secondary btn-sm">Edit</a>
                                <form asp-action="Delete" asp-route-id="@room.RoomId" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete Room @room.RoomNumber?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <p>No rooms found.</p>
        </div>
    }
    <div class="pagination-wrapper">
        <partial name="_Pagination" model="Model" />
    </div>
</div>